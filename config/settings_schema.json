[
  {
    "name": "theme_info",
    "theme_name": "Fashique",
    "theme_version": "1.0.0",
    "theme_author": "Fashique",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "t:general.branding",
    "settings": [
      {
        "type": "header",
        "content": "t:labels.branding_store"
      },
      {
        "type": "image_picker",
        "id": "logo",
        "label": "t:labels.logo",
        "info": "t:info.theme_logo"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 40,
        "max": 300,
        "step": 10,
        "unit": "px",
        "label": "t:labels.logo_width",
        "info": "t:info.theme_logo_width",
        "default": 140
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "t:labels.favicon",
        "info": "t:info.favicon"
      }
    ]
  },
  {
    "name": "t:general.color_schemes",
    "settings": [
      {
        "type": "color_scheme_group",
        "id": "color_schemes",
        "definition": [
          {
            "type": "color",
            "id": "background",
            "label": "t:labels.background",
            "default": "#FFFFFF"
          },
          {
            "type": "color",
            "id": "foreground",
            "label": "t:labels.foreground",
            "default": "#1A1A1A"
          },
          {
            "type": "color",
            "id": "primary",
            "label": "t:labels.color_primary",
            "default": "#1A1A1A"
          },
          {
            "type": "color",
            "id": "primary_hover",
            "label": "t:labels.color_primary_hover",
            "default": "#444444"
          },
          {
            "type": "color",
            "id": "border",
            "label": "t:labels.color_border",
            "default": "#E5E5E5"
          },
          {
            "type": "header",
            "content": "t:labels.buttons"
          },
          {
            "type": "color",
            "id": "btn_bg",
            "label": "t:labels.btn_bg",
            "info": "t:info.btn_bg",
            "default": "#1A1A1A"
          },
          {
            "type": "color",
            "id": "btn_text",
            "label": "t:labels.btn_text",
            "info": "t:info.btn_text",
            "default": "#FFFFFF"
          },
          {
            "type": "color",
            "id": "btn_bg_hover",
            "label": "t:labels.btn_bg_hover",
            "info": "t:info.btn_bg_hover",
            "default": "#444444"
          }
        ],
        "role": {
          "background": "background",
          "text": "foreground",
          "primary_button": "btn_bg",
          "on_primary_button": "btn_text",
          "primary_button_border": "btn_bg",
          "secondary_button": "primary",
          "on_secondary_button": "foreground",
          "secondary_button_border": "primary",
          "links": "primary",
          "icons": "foreground"
        }
      }
    ]
  },
  {
    "name": "t:general.colors_style",
    "settings": [
      {
        "type": "header",
        "content": "t:labels.base_colors"
      },
      {
        "type": "color",
        "id": "background_color",
        "default": "#FFFFFF",
        "label": "t:labels.background"
      },
      {
        "type": "color",
        "id": "foreground_color",
        "default": "#1A1A1A",
        "label": "t:labels.foreground"
      },
      {
        "type": "header",
        "content": "t:labels.accent_colors"
      },
      {
        "type": "color",
        "id": "color_primary",
        "default": "#1A1A1A",
        "label": "t:labels.color_primary",
        "info": "t:info.color_primary"
      },
      {
        "type": "color",
        "id": "color_primary_hover",
        "default": "#444444",
        "label": "t:labels.color_primary_hover",
        "info": "t:info.color_primary_hover"
      },
      {
        "type": "color",
        "id": "color_border",
        "default": "#E5E5E5",
        "label": "t:labels.color_border"
      },
      {
        "type": "header",
        "content": "t:labels.overlay"
      },
