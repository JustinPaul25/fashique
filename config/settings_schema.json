        "type": "color",
        "id": "color_overlay",
        "default": "#000000",
        "label": "t:labels.color_overlay"
      },
      {
        "type": "range",
        "id": "color_overlay_opacity",
        "min": 0,
        "max": 100,
        "step": 5,
        "unit": "%",
        "label": "t:labels.color_overlay_opacity",
        "info": "t:info.color_overlay_opacity",
        "default": 50
      },
      {
        "type": "header",
        "content": "t:labels.radius"
      },
      {
        "type": "range",
        "id": "border_radius_sm",
        "min": 0,
        "max": 20,
        "step": 1,
        "unit": "px",
        "label": "t:labels.border_radius_sm",
        "default": 2
      },
      {
        "type": "range",
        "id": "border_radius_md",
        "min": 0,
        "max": 20,
        "step": 1,
        "unit": "px",
        "label": "t:labels.border_radius_md",
        "default": 4
      },
      {
        "type": "range",
        "id": "border_radius_lg",
        "min": 0,
        "max": 30,
        "step": 1,
        "unit": "px",
        "label": "t:labels.border_radius_lg",
        "default": 8
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 4
      },
      {
        "type": "header",
        "content": "t:labels.buttons"
      },
      {
        "type": "select",
        "id": "btn_shape",
        "label": "t:labels.btn_shape",
        "info": "t:info.btn_shape",
        "options": [
          { "value": "rounded", "label": "t:options.btn_shape.rounded" },
          { "value": "pill", "label": "t:options.btn_shape.pill" },
          { "value": "sharp", "label": "t:options.btn_shape.sharp" }
        ],
        "default": "rounded"
      },
      {
        "type": "header",
        "content": "t:labels.transitions"
      },
      {
        "type": "select",
        "id": "transition_speed",
        "label": "t:labels.transition_speed",
        "info": "t:info.transition_speed",
        "options": [
          { "value": "fast", "label": "t:options.transition_speed.fast" },
          { "value": "normal", "label": "t:options.transition_speed.normal" },
          { "value": "slow", "label": "t:options.transition_speed.slow" }
        ],
        "default": "normal"
      }
    ]
  },
  {
    "name": "t:general.typography",
    "settings": [
