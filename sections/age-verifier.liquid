{%- comment -%}
  Age gate (Phase 8 / Feature #2). Render from layout only when settings.enable_age_verifier.
  localStorage key: age-verified. Script: component-age-verifier.js
{%- endcomment -%}
{%- liquid
    assign min_age = settings.age_verifier_minimum | default: 18
    assign decline = section.settings.decline_url
    if decline == blank
      assign decline = 'https://www.google.com'
    endif
  -%}

  <div
    id="age-verifier-{{ section.id }}"
    class="age-verifier"
    data-age-verifier
    data-decline-url="{{ decline | escape }}"
    {% if request.design_mode %}
      data-design-mode="true"
    {% endif %}
    role="dialog"
    aria-modal="true"
    aria-labelledby="age-verifier-heading-{{ section.id }}"
    aria-describedby="age-verifier-desc-{{ section.id }}"
  >
    <script>
      try {
        if (localStorage.getItem('age-verified') === 'true') {
          document.documentElement.classList.add('age-verifier-passed');
        }
      } catch (e) {}
    </script>
    <div class="age-verifier__backdrop" aria-hidden="true"></div>
    <div class="age-verifier__panel color-scheme color-{{ section.settings.color_scheme }}">
      <h2 id="age-verifier-heading-{{ section.id }}" class="age-verifier__heading">
        {%- if section.settings.heading != blank -%}
          {{ section.settings.heading | escape }}
        {%- else -%}
          {{ 'sections.age_verifier.heading' | t }}
        {%- endif -%}
      </h2>
      <p id="age-verifier-desc-{{ section.id }}" class="age-verifier__subtext">
        {%- if section.settings.subheading != blank -%}
          {{ section.settings.subheading | escape }}
        {%- else -%}
          {{ 'sections.age_verifier.subheading' | t: age: min_age }}
        {%- endif -%}
      </p>
      <p class="age-verifier__age-line">
        {{ 'sections.age_verifier.minimum_age_label' | t: age: min_age }}
      </p>
      <div class="age-verifier__actions">
        <button type="button" class="btn btn--solid age-verifier__confirm" data-age-confirm>
          {%- if section.settings.confirm_label != blank -%}
            {{ section.settings.confirm_label | escape }}
          {%- else -%}
            {{ 'sections.age_verifier.confirm' | t: age: min_age }}
          {%- endif -%}
        </button>
        <a href="{{ decline }}" class="btn btn--outline age-verifier__decline" data-age-decline>
          {%- if section.settings.decline_label != blank -%}
            {{ section.settings.decline_label | escape }}
          {%- else -%}
            {{ 'sections.age_verifier.decline' | t }}
          {%- endif -%}
        </a>
      </div>
    </div>
  </div>

  <script>
    (function () {
      var designMode = {% if request.design_mode %}true{% else %}false{% endif %};
      if (!designMode && document.documentElement.classList.contains('age-verifier-passed')) return;
      var s = document.createElement('script');
      s.src = '{{ 'component-age-verifier.js' | asset_url }}';
      s.defer = true;
      document.head.appendChild(s);
    })();
  </script>

  {% stylesheet %}
    html.age-verifier-passed .age-verifier {
      display: none !important;
      pointer-events: none;
    }

    .age-verifier {
      position: fixed;
      inset: 0;
      z-index: 99999;
      display: grid;
      place-items: center;
      padding: var(--spacing-md);
    }

    .age-verifier__backdrop {
      position: absolute;
      inset: 0;
      background: rgb(0 0 0 / 0.72);
    }

    .age-verifier__panel {
      position: relative;
      z-index: 1;
      width: min(100%, 26rem);
      padding: var(--spacing-xl);
      border-radius: var(--radius-md);
      border: 1px solid var(--color-border);
      background-color: var(--color-background);
      color: var(--color-foreground);
      text-align: center;
      box-shadow: 0 16px 48px rgb(0 0 0 / 0.35);
    }

    .age-verifier__heading {
      font-family: var(--font-heading-family);
      font-size: var(--font-size-h3);
      margin: 0 0 var(--spacing-sm);
    }

    .age-verifier__subtext,
    .age-verifier__age-line {
      margin: 0 0 var(--spacing-sm);
      font-size: 0.9375rem;
      line-height: 1.5;
      opacity: 0.9;
    }

    .age-verifier__actions {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-sm);
      margin-block-start: var(--spacing-md);
    }

    .age-verifier__confirm,
    .age-verifier__decline {
      width: 100%;
      justify-content: center;
      text-decoration: none;
    }
  {% endstylesheet %}

{% schema %}
{
  "name": "t:sections.age_verifier.name",
  "tag": "section",
  "class": "section-age-verifier",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.age_verifier.settings.intro"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:labels.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.age_verifier.settings.heading.label"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:sections.age_verifier.settings.subheading.label"
    },
    {
      "type": "text",
      "id": "confirm_label",
      "label": "t:sections.age_verifier.settings.confirm_label.label"
    },
    {
      "type": "text",
      "id": "decline_label",
      "label": "t:sections.age_verifier.settings.decline_label.label"
    },
    {
      "type": "url",
      "id": "decline_url",
      "label": "t:sections.age_verifier.settings.decline_url.label",
      "info": "t:sections.age_verifier.settings.decline_url.info"
    }
  ],
  "presets": [{ "name": "t:sections.age_verifier.name" }]
}
{% endschema %}
