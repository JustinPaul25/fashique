{%- comment -%}
  Before / After (Phase 8 / Feature #4): one or more pairs. Multiple pairs use Splide.
  Legacy: section-level before/after images when no valid pair blocks. JS: section-before-after.js
{%- endcomment -%}
{%- liquid
  assign orientation = section.settings.orientation | default: 'horizontal'
  assign pair_count = 0
  for block in section.blocks
    if block.type == 'pair'
      if block.settings.before_image != blank and block.settings.after_image != blank
        assign pair_count = pair_count | plus: 1
      endif
    endif
  endfor

  assign legacy_ok = false
  if section.settings.before_image != blank and section.settings.after_image != blank
    assign legacy_ok = true
  endif

  assign show_splide = false
  if pair_count > 1
    assign show_splide = true
  endif

  assign show_sliders = false
  if pair_count > 0
    assign show_sliders = true
  elsif legacy_ok
    assign show_sliders = true
  endif
-%}

{%- render 'section-spacing', section: section -%}
<section
  class="before-after section-padding color-scheme color-{{ section.settings.color_scheme }}"
  data-section-id="{{ section.id }}"
>
  <div class="page-width">
    {%- if section.settings.heading != blank or section.settings.subtext != blank -%}
      <div class="before-after__header">
        {%- if section.settings.heading != blank -%}
          <h2 class="before-after__heading section-heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.subtext != blank -%}
          <p class="before-after__subtext">{{ section.settings.subtext | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if show_sliders -%}
      {%- if show_splide -%}
        <div
          class="splide before-after__splide"
          data-splide-config='{"type":"slide","perPage":1,"perMove":1,"gap":"var(--spacing-lg)","arrows":true,"pagination":true,"rewind":true}'
        >
          <div class="splide__track">
            <ul class="splide__list" role="list">
              {%- for block in section.blocks -%}
                {%- if block.type == 'pair'
                  and block.settings.before_image != blank
                  and block.settings.after_image != blank
                -%}
                  <li class="splide__slide" {{ block.shopify_attributes }}>
                    {%- render 'before-after-slide',
                      id_base: block.id,
                      orientation: orientation,
                      before_image: block.settings.before_image,
                      after_image: block.settings.after_image,
                      before_label: block.settings.before_label,
                      after_label: block.settings.after_label
                    -%}
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>
        </div>
        <link
          rel="stylesheet"
          href="{{ 'splide.min.css' | asset_url }}"
          media="print"
          onload="this.media='all'"
        >
        <noscript><link rel="stylesheet" href="{{ 'splide.min.css' | asset_url }}"></noscript>
        <script src="{{ 'splide.min.js' | asset_url }}" defer></script>
        <script src="{{ 'splide-init.js' | asset_url }}" defer></script>
      {%- elsif pair_count == 1 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'pair'
            and block.settings.before_image != blank
            and block.settings.after_image != blank
          -%}
            <div {{ block.shopify_attributes }}>
              {%- render 'before-after-slide',
                id_base: block.id,
                orientation: orientation,
                before_image: block.settings.before_image,
                after_image: block.settings.after_image,
                before_label: block.settings.before_label,
                after_label: block.settings.after_label
              -%}
            </div>
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}
      {%- elsif legacy_ok -%}
        {%- render 'before-after-slide',
          id_base: section.id,
          orientation: orientation,
          before_image: section.settings.before_image,
          after_image: section.settings.after_image,
          before_label: section.settings.before_label,
          after_label: section.settings.after_label
        -%}
      {%- endif -%}

      <script src="{{ 'section-before-after.js' | asset_url }}" defer></script>
    {%- elsif request.design_mode -%}
      <p class="before-after__editor-hint">{{ 'sections.before_after.editor_hint' | t }}</p>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .before-after {
    background-color: var(--color-background);
    color: var(--color-foreground);
    padding-block: var(--section-padding-block);
  }

  .before-after__header {
    text-align: center;
    margin-block-end: var(--spacing-xl);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    align-items: center;
  }

  .before-after__heading {
    font-size: var(--font-size-h2);
    font-family: var(--font-heading-family);
    font-weight: var(--font-heading-weight);
    letter-spacing: var(--font-heading-letter-spacing, -0.02em);
    line-height: var(--font-heading-line-height, 1.1);
    margin: 0;
  }

  .before-after__subtext {
    font-size: 1rem;
    line-height: 1.6;
    opacity: 0.75;
    max-width: 44ch;
    margin: 0;
  }

  .before-after__editor-hint {
    text-align: center;
    opacity: 0.7;
    font-size: 0.9375rem;
  }

  .before-after__splide {
    margin-inline: auto;
  }

  .before-after__slider {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-md);
    aspect-ratio: 16 / 9;
    user-select: none;
    touch-action: none;
    cursor: col-resize;
  }

  .before-after__slider--vertical {
    cursor: row-resize;
    aspect-ratio: 4 / 3;
  }

  .before-after__after-wrap {
    position: absolute;
    inset: 0;
  }

  .before-after__before-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
    clip-path: inset(0 50% 0 0);
  }

  .before-after__slider--vertical .before-after__before-wrap {
    clip-path: inset(0 0 50% 0);
  }

  .before-after__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
  }

  .before-after__badge {
    position: absolute;
    bottom: var(--spacing-sm);
    padding: 0.25em 0.75em;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background-color: rgba(0, 0, 0, 0.55);
    color: #fff;
    border-radius: var(--radius-sm);
    pointer-events: none;
    backdrop-filter: blur(4px);
  }

  .before-after__badge--before {
    inset-inline-start: var(--spacing-sm);
  }
  .before-after__badge--after {
    inset-inline-end: var(--spacing-sm);
  }

  .before-after__divider {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 3px;
    background-color: #fff;
    translate: -50% 0;
    cursor: col-resize;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .before-after__slider--vertical .before-after__divider {
    top: 50%;
    left: 0;
    right: 0;
    bottom: auto;
    width: 100%;
    height: 3px;
    translate: 0 -50%;
    cursor: row-resize;
    flex-direction: row;
  }

  .before-after__divider:focus-visible {
    outline: 3px solid var(--color-primary);
    outline-offset: 2px;
  }

  .before-after__handle {
    position: relative;
    z-index: 11;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    background-color: #fff;
    border-radius: 50%;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.25);
    color: #1a1a1a;
    flex-shrink: 0;
  }

  .before-after__slider--vertical .before-after__handle {
    flex-direction: column;
  }

  .before-after__after-wrap .image-placeholder,
  .before-after__before-wrap .image-placeholder {
    position: absolute;
    inset: 0;
  }

  .before-after__after-wrap .placeholder-svg,
  .before-after__before-wrap .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.before_after.name",
  "tag": "section",
  "class": "section-before-after",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.before_after.settings.legacy_info"
    },
    {
      "type": "image_picker",
      "id": "before_image",
      "label": "t:sections.before_after.settings.before_image.label"
    },
    {
      "type": "image_picker",
      "id": "after_image",
      "label": "t:sections.before_after.settings.after_image.label"
    },
    {
      "type": "text",
      "id": "before_label",
      "label": "t:sections.before_after.settings.before_label.label",
      "default": "Before"
    },
    {
      "type": "text",
      "id": "after_label",
      "label": "t:sections.before_after.settings.after_label.label",
      "default": "After"
    },
    {
      "type": "select",
      "id": "orientation",
      "label": "t:sections.before_after.settings.orientation.label",
      "options": [
        { "value": "horizontal", "label": "t:options.orientation.horizontal" },
        { "value": "vertical", "label": "t:options.orientation.vertical" }
      ],
      "default": "horizontal"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.before_after.settings.heading.label"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "t:sections.before_after.settings.subtext.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:labels.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_spacing",
      "label": "t:labels.section_spacing",
      "info": "t:info.section_spacing",
      "options": [
        { "value": "default", "label": "t:options.section_spacing.default" },
        { "value": "none", "label": "t:options.section_spacing.none" },
        { "value": "xs", "label": "t:options.section_spacing.xs" },
        { "value": "sm", "label": "t:options.section_spacing.sm" },
        { "value": "md", "label": "t:options.section_spacing.md" },
        { "value": "lg", "label": "t:options.section_spacing.lg" },
        { "value": "xl", "label": "t:options.section_spacing.xl" }
      ],
      "default": "none"
    }
  ],
  "blocks": [
    {
      "type": "pair",
      "name": "t:sections.before_after.blocks.pair.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "before_image",
          "label": "t:sections.before_after.settings.before_image.label"
        },
        {
          "type": "image_picker",
          "id": "after_image",
          "label": "t:sections.before_after.settings.after_image.label"
        },
        {
          "type": "text",
          "id": "before_label",
          "label": "t:sections.before_after.settings.before_label.label",
          "default": "Before"
        },
        {
          "type": "text",
          "id": "after_label",
          "label": "t:sections.before_after.settings.after_label.label",
          "default": "After"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.before_after.name",
      "settings": {
        "before_label": "Before",
        "after_label": "After",
        "orientation": "horizontal",
        "heading": "See the transformation",
        "subtext": "Drag the slider to compare before and after."
      },
      "blocks": [
        {
          "type": "pair",
          "settings": {
            "before_label": "Before",
            "after_label": "After"
          }
        }
      ]
    }
  ]
}
{% endschema %}
