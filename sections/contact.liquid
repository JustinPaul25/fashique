{%- comment -%}
  Contact page (Phase 5.9): contact form, map URL iframe, contact details. Use with template `page.contact`.
{%- endcomment -%}

{%- render 'section-spacing', section: section -%}

<div class="contact-page section-padding color-scheme color-{{ section.settings.color_scheme }}">
  <div class="contact-page__inner page-width">
    {%- if section.settings.show_breadcrumbs -%}
      <div class="contact-page__breadcrumbs">
        {%- render 'breadcrumbs', show: true -%}
      </div>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="contact-page__title">{{ section.settings.heading | escape }}</h1>
    {%- else -%}
      <h1 class="contact-page__title">{{ page.title | escape }}</h1>
    {%- endif -%}

    {%- if section.settings.intro != blank -%}
      <div class="contact-page__intro rte">{{ section.settings.intro }}</div>
    {%- endif -%}

    <div class="contact-page__grid">
      <div class="contact-page__form-col">
        <h2 class="contact-page__subheading">{{ 'sections.contact.form_heading' | t }}</h2>

        {%- assign contact_form_id = 'ContactForm-' | append: section.id -%}
        {%- form 'contact', id: contact_form_id, class: 'contact-page__form' -%}
          {%- if form.posted_successfully? -%}
            <p class="contact-page__success" role="status">{{ 'sections.contact.success' | t }}</p>
          {%- endif -%}

          {%- if form.errors -%}
            <div class="contact-page__errors" role="alert">
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}

          <div class="contact-page__field">
            <label class="contact-page__label" for="ContactName-{{ section.id }}">
              {{- 'sections.contact.name' | t -}}
            </label>
            <input
              type="text"
              id="ContactName-{{ section.id }}"
              class="contact-page__input"
              name="contact[name]"
              autocomplete="name"
              value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
              required
            >
          </div>

          <div class="contact-page__field">
            <label class="contact-page__label" for="ContactEmail-{{ section.id }}">
              {{- 'sections.contact.email' | t -}}
            </label>
            <input
              type="email"
              id="ContactEmail-{{ section.id }}"
              class="contact-page__input"
              name="contact[email]"
              autocomplete="email"
              value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
              required
            >
          </div>

          <div class="contact-page__field">
            <label class="contact-page__label" for="ContactPhone-{{ section.id }}">
              {{- 'sections.contact.phone' | t -}}
            </label>
            <input
              type="tel"
              id="ContactPhone-{{ section.id }}"
              class="contact-page__input"
              name="contact[phone]"
              autocomplete="tel"
              value="{% if form.phone %}{{ form.phone }}{% endif %}"
            >
          </div>

          <div class="contact-page__field">
            <label class="contact-page__label" for="ContactBody-{{ section.id }}">
              {{- 'sections.contact.message' | t -}}
            </label>
            <textarea
              id="ContactBody-{{ section.id }}"
              class="contact-page__textarea"
              name="contact[body]"
              rows="6"
              required
            >{% if form.body %}{{ form.body }}{% endif %}</textarea>
          </div>

          <button type="submit" class="btn btn--solid contact-page__submit">
            {{- 'sections.contact.submit' | t -}}
          </button>
        {%- endform -%}
      </div>

      <div class="contact-page__aside">
        {%- liquid
          assign has_info = false
          if section.settings.address != blank or section.settings.phone != blank or section.settings.email != blank
            assign has_info = true
          endif
        -%}
        {%- if has_info -%}
          <div class="contact-page__info">
            <h2 class="contact-page__subheading">{{ 'sections.contact.info_heading' | t }}</h2>
            {%- if section.settings.address != blank -%}
              <div class="contact-page__info-block">
                <h3 class="contact-page__info-label">{{ 'sections.contact.address_label' | t }}</h3>
                <div class="contact-page__info-text rte">{{ section.settings.address }}</div>
              </div>
            {%- endif -%}
            {%- if section.settings.phone != blank -%}
              <div class="contact-page__info-block">
                <h3 class="contact-page__info-label">{{ 'sections.contact.phone_label' | t }}</h3>
                <p class="contact-page__info-text">
                  <a href="tel:{{ section.settings.phone | strip | replace: ' ', '' | replace: '(', '' | replace: ')', '' }}">
                    {{- section.settings.phone | escape -}}
                  </a>
                </p>
              </div>
            {%- endif -%}
            {%- if section.settings.email != blank -%}
              <div class="contact-page__info-block">
                <h3 class="contact-page__info-label">{{ 'sections.contact.email_label' | t }}</h3>
                <p class="contact-page__info-text">
                  <a href="mailto:{{ section.settings.email | escape }}">{{ section.settings.email | escape }}</a>
                </p>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if section.settings.map_embed_url != blank -%}
          <div class="contact-page__map">
            <h2 class="contact-page__subheading">{{ 'sections.contact.map_heading' | t }}</h2>
            <div class="contact-page__map-embed">
              <iframe
                class="contact-page__iframe"
                src="{{ section.settings.map_embed_url | escape }}"
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="{{ 'sections.contact.map_heading' | t }}"
                allowfullscreen
              ></iframe>
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .contact-page__inner {
    max-width: var(--page-width);
    margin-inline: auto;
  }

  .contact-page__breadcrumbs {
    margin-bottom: var(--spacing-md);
  }

  .contact-page__title {
    margin: 0 0 var(--spacing-sm);
    font-size: clamp(1.75rem, 4vw, 2.25rem);
  }

  .contact-page__intro {
    margin-bottom: var(--spacing-xl);
    max-width: 40rem;
  }

  .contact-page__grid {
    display: grid;
    gap: var(--spacing-xl);
    align-items: start;
  }

  @media screen and (min-width: 990px) {
    .contact-page__grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 22rem);
    }
  }

  .contact-page__subheading {
    font-size: 1.125rem;
    margin: 0 0 var(--spacing-md);
  }

  .contact-page__field {
    margin-bottom: var(--spacing-md);
  }

  .contact-page__label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: var(--spacing-xs);
  }

  .contact-page__input,
  .contact-page__textarea {
    width: 100%;
    max-width: 32rem;
    min-height: 2.75rem;
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    background: var(--color-background);
    color: inherit;
    font: inherit;
  }

  .contact-page__textarea {
    min-height: 8rem;
    resize: vertical;
  }

  .contact-page__submit {
    margin-top: var(--spacing-sm);
    min-height: 3rem;
  }

  .contact-page__success {
    padding: var(--spacing-sm);
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--color-primary) 12%, var(--color-background));
    margin-bottom: var(--spacing-md);
  }

  .contact-page__errors {
    margin-bottom: var(--spacing-md);
  }

  .contact-page__info {
    padding: var(--spacing-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    margin-bottom: var(--spacing-lg);
  }

  .contact-page__info-block {
    margin-bottom: var(--spacing-md);
  }

  .contact-page__info-block:last-child {
    margin-bottom: 0;
  }

  .contact-page__info-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 var(--spacing-xs);
    opacity: 0.75;
  }

  .contact-page__info-text {
    margin: 0;
  }

  .contact-page__map-embed {
    position: relative;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--color-border);
    aspect-ratio: 4 / 3;
    max-height: 20rem;
  }

  .contact-page__map-embed iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.contact.name",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:labels.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_spacing",
      "label": "t:labels.section_spacing",
      "info": "t:info.section_spacing",
      "options": [
        { "value": "default", "label": "t:options.section_spacing.default" },
        { "value": "none", "label": "t:options.section_spacing.none" },
        { "value": "xs", "label": "t:options.section_spacing.xs" },
        { "value": "sm", "label": "t:options.section_spacing.sm" },
        { "value": "md", "label": "t:options.section_spacing.md" },
        { "value": "lg", "label": "t:options.section_spacing.lg" },
        { "value": "xl", "label": "t:options.section_spacing.xl" }
      ],
      "default": "md"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumbs",
      "label": "t:sections.page.settings.show_breadcrumbs.label",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.contact.settings.heading.label",
      "info": "t:sections.contact.settings.heading.info"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "t:sections.contact.settings.intro.label"
    },
    {
      "type": "header",
      "content": "t:sections.contact.settings.header_info"
    },
    {
      "type": "richtext",
      "id": "address",
      "label": "t:sections.contact.settings.address.label"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "t:sections.contact.settings.phone.label"
    },
    {
      "type": "text",
      "id": "email",
      "label": "t:sections.contact.settings.email.label"
    },
    {
      "type": "url",
      "id": "map_embed_url",
      "label": "t:sections.contact.settings.map_embed_url.label",
      "info": "t:sections.contact.settings.map_embed_url.info"
    }
  ]
}
{% endschema %}
