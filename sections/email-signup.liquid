{%- comment -%}
  Email Sign-up  (Phase 5.1)
  ───────────────────────────
  • Full-width newsletter CTA section.
  • Optional background image with overlay.
  • Uses Shopify's {% form 'customer' %} with type 'create_customer' hidden input approach,
    or the standard newsletter form. We use the dedicated newsletter contact form.
{%- endcomment -%}

{%- assign overlay_alpha = section.settings.overlay_opacity | divided_by: 100.0 | default: 0 -%}
{%- assign has_image = false -%}
{%- if section.settings.image != blank -%}
  {%- assign has_image = true -%}
{%- endif -%}

{%- render 'section-spacing', section: section -%}
<section
  class="email-signup section-padding color-scheme color-{{ section.settings.color_scheme }}{% if has_image %} email-signup--has-image{% endif %}"
  data-section-id="{{ section.id }}"
>
  {%- if has_image -%}
    <div class="email-signup__bg">
      {%- render 'image',
        image: section.settings.image,
        widths: '750,1100,1500,2000',
        sizes: '100vw',
        alt: section.settings.image.alt | default: section.settings.heading,
        class: 'email-signup__bg-img',
        loading: 'lazy',
            placeholder_type: 'lifestyle-2'
      -%}
    </div>
    <div
      class="email-signup__overlay"
      style="--overlay-alpha: {{ overlay_alpha }}"
      aria-hidden="true"
    ></div>
  {%- endif -%}

  <div class="page-width email-signup__content">

    {%- if section.settings.heading != blank -%}
      <h2 class="email-signup__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if section.settings.subtext != blank -%}
      <p class="email-signup__subtext">{{ section.settings.subtext | escape }}</p>
    {%- endif -%}

    {%- assign signup_form_id = 'email-signup-' | append: section.id -%}
    {%- form 'customer', id: signup_form_id -%}
      <input type="hidden" name="contact[tags]" value="newsletter">

      {%- if form.posted_successfully? -%}
        <p class="email-signup__success" role="status">
          {{- 'sections.email_signup.success' | t -}}
        </p>
      {%- else -%}
        <div class="email-signup__form-row">
          <label for="email-signup-input-{{ section.id }}" class="visually-hidden">
            {{- section.settings.heading | default: 'Email' | escape -}}
          </label>
          <input
            type="email"
            id="email-signup-input-{{ section.id }}"
            class="email-signup__input"
            name="contact[email]"
            autocomplete="email"
            aria-required="true"
            placeholder="{{ 'sections.email_signup.placeholder' | t }}"
            required
          >
          <button type="submit" class="email-signup__btn btn btn--solid">
            {{- section.settings.button_label | default: 'Subscribe' | escape -}}
          </button>
        </div>

        {%- if form.errors -%}
          <p class="email-signup__error" role="alert">
            {{- 'sections.email_signup.error' | t -}}
          </p>
        {%- endif -%}
      {%- endif -%}
    {%- endform -%}

  </div>
</section>

{% stylesheet %}
  /* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
     EMAIL SIGN-UP
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

  .email-signup {
    position: relative;
    background-color: var(--color-background);
    color: var(--color-foreground);
    padding-block: var(--section-padding-block);
    text-align: center;
    overflow: hidden;
  }

  /* ── Background image ─────────────────────────────────────────────── */
  .email-signup__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .email-signup__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .email-signup__bg .image-placeholder {
    width: 100%;
    height: 100%;
  }

  .email-signup__bg .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .email-signup__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background-color: rgba(0, 0, 0, var(--overlay-alpha, 0));
    pointer-events: none;
  }

  /* ── Content ──────────────────────────────────────────────────────── */
  .email-signup__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-md);
  }

  .email-signup--has-image .email-signup__content {
    color: #fff;
  }

  .email-signup__heading {
    font-size: var(--font-size-h2);
    font-family: var(--font-heading-family);
    font-weight: var(--font-heading-weight);
    letter-spacing: var(--font-heading-letter-spacing, -0.02em);
    line-height: var(--font-heading-line-height, 1.1);
    margin: 0;
    max-width: 24ch;
  }

  .email-signup__subtext {
    font-size: clamp(1rem, 1.5vw, 1.0625rem);
    line-height: 1.6;
    opacity: 0.8;
    margin: 0;
    max-width: 44ch;
  }

  /* ── Form row ─────────────────────────────────────────────────────── */
  .email-signup__form-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    justify-content: center;
    width: 100%;
    max-width: 36rem;
  }

  .email-signup__input {
    flex: 1 1 16rem;
    min-height: 3rem;
    padding: 0.75rem 1rem;
    font-size: 0.9375rem;
    background-color: var(--color-background);
    color: var(--color-foreground);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-inputs, 4px);
    transition: border-color var(--transition-base);
  }

  .email-signup--has-image .email-signup__input {
    background-color: rgba(255, 255, 255, 0.12);
    color: #fff;
    border-color: rgba(255, 255, 255, 0.4);
  }

  .email-signup--has-image .email-signup__input::placeholder {
    color: rgba(255, 255, 255, 0.7);
  }

  .email-signup__input:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    border-color: var(--color-primary);
  }

  .email-signup__btn {
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── Status messages ──────────────────────────────────────────────── */
  .email-signup__success {
    font-weight: 500;
    color: var(--color-primary);
  }

  .email-signup__error {
    font-size: 0.875rem;
    color: #c0392b;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.email_signup.name",
  "tag": "section",
  "class": "section-email-signup",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.email_signup.settings.heading.label",
      "default": "Stay in the loop"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "t:sections.email_signup.settings.subtext.label",
      "default": "New arrivals, exclusive offers, and style inspiration — straight to your inbox."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.email_signup.settings.button_label.label",
      "default": "Subscribe"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.email_signup.settings.image.label"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "t:sections.image_banner.settings.overlay_opacity.label",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 0
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:labels.color_scheme",
      "default": "scheme-3"
    },
    {
      "type": "select",
      "id": "section_spacing",
      "label": "t:labels.section_spacing",
      "info": "t:info.section_spacing",
      "options": [
        { "value": "default", "label": "t:options.section_spacing.default" },
        { "value": "none",    "label": "t:options.section_spacing.none"    },
        { "value": "xs",      "label": "t:options.section_spacing.xs"      },
        { "value": "sm",      "label": "t:options.section_spacing.sm"      },
        { "value": "md",      "label": "t:options.section_spacing.md"      },
        { "value": "lg",      "label": "t:options.section_spacing.lg"      },
        { "value": "xl",      "label": "t:options.section_spacing.xl"      }
      ],
      "default": "default"
    }
  ],
  "presets": [
    {
      "name": "t:sections.email_signup.name",
      "settings": {
        "heading": "Stay in the loop",
        "subtext": "New arrivals, exclusive offers, and style inspiration — straight to your inbox.",
        "button_label": "Subscribe"
      }
    }
  ]
}
{% endschema %}
