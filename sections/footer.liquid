{%- liquid
  assign show_footer_lang    = false
  if section.settings.show_language_selector and localization.available_languages.size > 1
    assign show_footer_lang = true
  endif
  assign show_footer_country = false
  if section.settings.show_country_selector and localization.available_countries.size > 1
    assign show_footer_country = true
  endif
  assign show_footer_localization = false
  if show_footer_lang or show_footer_country
    assign show_footer_localization = true
  endif
  assign show_footer_payment = section.settings.show_payment_icons | default: settings.footer_show_payment_icons, allow_false: true
-%}

<footer
  class="site-footer full-width color-scheme color-{{ section.settings.color_scheme }}"
  role="contentinfo"
>
  {%- comment -%} ── Block grid ─────────────────────────────────────────── {%- endcomment -%}
  {%- if section.blocks.size > 0 -%}
    <div class="footer__main">
      <div class="footer__blocks">

        {%- for block in section.blocks -%}

          {%- case block.type -%}

            {%- when 'link_list' -%}
              <div class="footer-block footer-block--link-list" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                  <p class="footer-block__heading">{{ block.settings.heading }}</p>
                {%- endif -%}
                {%- if block.settings.menu != blank -%}
                  <ul class="footer-block__list" role="list">
                    {%- for link in block.settings.menu.links -%}
                      <li>
                        <a
                          href="{{ link.url }}"
                          class="footer-block__link{% if link.active %} is-active{% endif %}"
                        >{{ link.title }}</a>
                      </li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}
              </div>

            {%- when 'newsletter' -%}
              <div class="footer-block footer-block--newsletter" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                  <p class="footer-block__heading">{{ block.settings.heading }}</p>
                {%- endif -%}
                {%- if block.settings.description != blank -%}
                  <div class="footer-block__description rte">{{ block.settings.description }}</div>
                {%- endif -%}
                {%- form 'customer', id: 'footer-newsletter-form', class: 'footer-newsletter__form' -%}
                  <input type="hidden" name="contact[tags]" value="newsletter">
                  <div class="footer-newsletter__field">
                    <label for="footer-newsletter-email" class="visually-hidden">
                      {{ 'footer.newsletter.email_placeholder' | t }}
                    </label>
                    <input
                      type="email"
                      name="contact[email]"
                      id="footer-newsletter-email"
                      class="footer-newsletter__input"
                      placeholder="{{ 'footer.newsletter.email_placeholder' | t }}"
                      required
                      autocorrect="off"
                      autocapitalize="off"
                      {% if form.errors %}aria-invalid="true" aria-describedby="footer-newsletter-error"{% endif %}
                      value="{{ form.email }}"
                    >
                    <button type="submit" class="footer-newsletter__btn">
                      {{- 'footer.newsletter.submit' | t -}}
                    </button>
                  </div>
                  {%- if form.posted_successfully? -%}
                    <p class="footer-newsletter__message footer-newsletter__message--success" role="status">
                      {{ 'footer.newsletter.success' | t }}
                    </p>
                  {%- endif -%}
                  {%- if form.errors -%}
                    <p
                      id="footer-newsletter-error"
                      class="footer-newsletter__message footer-newsletter__message--error"
                      role="alert"
                    >
                      {{ form.errors.translated_fields['email'] | capitalize }}
                      {{ form.errors.messages['email'] }}
                    </p>
                  {%- endif -%}
                {%- endform -%}
              </div>

            {%- when 'social' -%}
              {%- unless settings.footer_show_social_icons == false -%}
              <div class="footer-block footer-block--social" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                  <p class="footer-block__heading">{{ block.settings.heading }}</p>
                {%- endif -%}
                <ul class="footer-social__list" role="list">
                  {%- if block.settings.instagram_url != blank -%}
                    <li>
                      <a
                        href="{{ block.settings.instagram_url }}"
                        class="footer-social__link"
                        aria-label="Instagram"
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="20" height="20"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/></svg>
                      </a>
                    </li>
                  {%- endif -%}
                  {%- if block.settings.facebook_url != blank -%}
                    <li>
                      <a
                        href="{{ block.settings.facebook_url }}"
                        class="footer-social__link"
                        aria-label="Facebook"
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="20" height="20"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                      </a>
                    </li>
                  {%- endif -%}
                  {%- if block.settings.tiktok_url != blank -%}
                    <li>
                      <a
                        href="{{ block.settings.tiktok_url }}"
                        class="footer-social__link"
                        aria-label="TikTok"
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="20" height="20"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.19a8.27 8.27 0 0 0 4.83 1.55V6.29a4.85 4.85 0 0 1-1.06-.4z"/></svg>
                      </a>
                    </li>
                  {%- endif -%}
                  {%- if block.settings.pinterest_url != blank -%}
                    <li>
                      <a
                        href="{{ block.settings.pinterest_url }}"
                        class="footer-social__link"
                        aria-label="Pinterest"
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="20" height="20"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
                      </a>
                    </li>
                  {%- endif -%}
                  {%- if block.settings.twitter_url != blank -%}
                    <li>
                      <a
                        href="{{ block.settings.twitter_url }}"
                        class="footer-social__link"
                        aria-label="X / Twitter"
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="20" height="20"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                      </a>
                    </li>
                  {%- endif -%}
                  {%- if block.settings.youtube_url != blank -%}
                    <li>
                      <a
                        href="{{ block.settings.youtube_url }}"
                        class="footer-social__link"
                        aria-label="YouTube"
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="20" height="20"><path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0C.488 3.45.029 5.804 0 12c.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0C23.512 20.55 23.971 18.196 24 12c-.029-6.185-.484-8.549-4.385-8.816zM9 16V8l8 3.993L9 16z"/></svg>
                      </a>
                    </li>
                  {%- endif -%}
                </ul>
              </div>
              {%- endunless -%}

            {%- when 'text' -%}
              <div class="footer-block footer-block--text" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                  <p class="footer-block__heading">{{ block.settings.heading }}</p>
                {%- endif -%}
                {%- if block.settings.content != blank -%}
                  <div class="footer-block__content rte">{{ block.settings.content }}</div>
                {%- endif -%}
              </div>

          {%- endcase -%}

        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ── Bottom bar ─────────────────────────────────────────── {%- endcomment -%}
  <div class="footer__bottom">
    <div class="footer__bottom-inner">

      {%- comment -%} Copyright text {%- endcomment -%}
      <div class="footer__copyright">
        {%- if section.settings.copyright_text != blank -%}
          {{ section.settings.copyright_text }}
        {%- else -%}
          <p>
            &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}
            &nbsp;&middot;&nbsp;
            {{ powered_by_link }}
          </p>
        {%- endif -%}
      </div>

      {%- comment -%} Language / currency selectors {%- endcomment -%}
      {%- if show_footer_localization -%}
        <div class="footer__localization">

          {%- if show_footer_lang -%}
            {%- form 'localization', class: 'footer-localization__form' -%}
              <label for="footer-lang-select" class="visually-hidden">
                {{- 'accessibility.language_select' | t -}}
              </label>
              <div class="footer-localization__select-wrap">
                <select
                  id="footer-lang-select"
                  name="locale_code"
                  class="footer-localization__select"
                  data-localization-select
                >
                  {%- for language in localization.available_languages -%}
                    <option
                      value="{{ language.iso_code }}"
                      {% if language.iso_code == localization.language.iso_code %}selected{% endif %}
                    >
                      {{- language.endonym_name | capitalize -}}
                    </option>
                  {%- endfor -%}
                </select>
                <span class="footer-localization__chevron" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="12" height="12" aria-hidden="true"><path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06z" clip-rule="evenodd"/></svg>
                </span>
              </div>
              <input type="hidden" name="currency_code" value="{{ localization.country.currency.iso_code }}">
            {%- endform -%}
          {%- endif -%}

          {%- if show_footer_country -%}
            {%- form 'localization', class: 'footer-localization__form' -%}
              <label for="footer-country-select" class="visually-hidden">
                {{- 'accessibility.currency_select' | t -}}
              </label>
              <div class="footer-localization__select-wrap">
                <select
                  id="footer-country-select"
                  name="country_code"
                  class="footer-localization__select"
                  data-localization-select
                >
                  {%- for country in localization.available_countries -%}
                    <option
                      value="{{ country.iso_code }}"
                      {% if country.iso_code == localization.country.iso_code %}selected{% endif %}
                    >
                      {{- country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol -}})
                    </option>
                  {%- endfor -%}
                </select>
                <span class="footer-localization__chevron" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="12" height="12" aria-hidden="true"><path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06z" clip-rule="evenodd"/></svg>
                </span>
              </div>
              <input type="hidden" name="locale_code" value="{{ localization.language.iso_code }}">
            {%- endform -%}
          {%- endif -%}

        </div>
      {%- endif -%}

      {%- comment -%} Payment icons {%- endcomment -%}
      {%- if show_footer_payment and shop.enabled_payment_types != empty -%}
        <ul
          class="footer__payment-list"
          role="list"
          aria-label="{{ 'footer.payment_methods' | t }}"
        >
          {%- for type in shop.enabled_payment_types -%}
            <li>{{ type | payment_type_svg_tag: class: 'footer__payment-icon' }}</li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

    </div>
  </div>
</footer>

{% stylesheet %}
  /* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
     FOOTER
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

  .site-footer {
    background-color: var(--color-background);
    color: var(--color-foreground);
    border-top: 1px solid var(--color-border);
  }

  /* ── Block grid ─────────────────────────────────────────────────────── */
  .footer__main {
    max-width: var(--page-width);
    margin-inline: auto;
    padding: 3.5rem var(--page-margin) 2.5rem;
  }

  .footer__blocks {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 2.5rem 3rem;
  }

  /* Newsletter block naturally spans wider on larger grids */
  .footer-block--newsletter {
    grid-column: span 2;
  }

  @media (max-width: 749px) {
    .footer-block--newsletter {
      grid-column: span 1;
    }
  }

  /* ── Block typography ───────────────────────────────────────────────── */
  .footer-block__heading {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-foreground);
    margin: 0 0 1rem;
  }

  .footer-block__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-block__link {
    display: inline-block;
    font-size: 0.9375rem;
    color: color-mix(in srgb, var(--color-foreground) 72%, transparent);
    text-decoration: none;
    transition: color var(--transition-base, 0.25s ease);
  }

  .footer-block__link:hover,
  .footer-block__link.is-active {
    color: var(--color-foreground);
  }

  .footer-block__description {
    font-size: 0.9375rem;
    color: color-mix(in srgb, var(--color-foreground) 70%, transparent);
    margin-bottom: 1.25rem;
    line-height: 1.6;
  }

  .footer-block__content {
    font-size: 0.9375rem;
    color: color-mix(in srgb, var(--color-foreground) 72%, transparent);
    line-height: 1.6;
  }

  /* ── Newsletter form ────────────────────────────────────────────────── */
  .footer-newsletter__form {
    max-width: 420px;
  }

  .footer-newsletter__field {
    display: flex;
    gap: 0.5rem;
  }

  .footer-newsletter__input {
    flex: 1;
    min-width: 0;
    height: 2.75rem;
    padding-inline: 0.875rem;
    background-color: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm, 2px);
    color: var(--color-foreground);
    font-family: inherit;
    font-size: 0.9375rem;
    transition: border-color var(--transition-base, 0.25s ease);
    outline: none;
  }

  .footer-newsletter__input::placeholder {
    color: color-mix(in srgb, var(--color-foreground) 45%, transparent);
  }

  .footer-newsletter__input:focus {
    border-color: var(--color-primary);
  }

  .footer-newsletter__input[aria-invalid="true"] {
    border-color: var(--color-error, #c0392b);
  }

  .footer-newsletter__btn {
    flex-shrink: 0;
    height: 2.75rem;
    padding-inline: 1.25rem;
    background-color: var(--color-primary);
    color: var(--color-primary-contrast, #fff);
    border: none;
    border-radius: var(--radius-sm, 2px);
    font-family: inherit;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
    transition: opacity var(--transition-base, 0.25s ease);
    white-space: nowrap;
  }

  .footer-newsletter__btn:hover {
    opacity: 0.85;
  }

  .footer-newsletter__message {
    margin: 0.75rem 0 0;
    font-size: 0.875rem;
  }

  .footer-newsletter__message--success {
    color: var(--color-success, #2e7d32);
  }

  .footer-newsletter__message--error {
    color: var(--color-error, #c0392b);
  }

  /* ── Social icons ───────────────────────────────────────────────────── */
  .footer-social__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }

  .footer-social__link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid var(--color-border);
    border-radius: 50%;
    color: color-mix(in srgb, var(--color-foreground) 70%, transparent);
    text-decoration: none;
    transition:
      color var(--transition-base, 0.25s ease),
      border-color var(--transition-base, 0.25s ease),
      background-color var(--transition-base, 0.25s ease);
  }

  .footer-social__link:hover {
    color: var(--color-foreground);
    border-color: var(--color-foreground);
    background-color: color-mix(in srgb, var(--color-foreground) 6%, transparent);
  }

  /* ── Bottom bar ─────────────────────────────────────────────────────── */
  .footer__bottom {
    border-top: 1px solid var(--color-border);
  }

  .footer__bottom-inner {
    max-width: var(--page-width);
    margin-inline: auto;
    padding: 1.25rem var(--page-margin);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem 2rem;
  }

  /* ── Copyright ──────────────────────────────────────────────────────── */
  .footer__copyright,
  .footer__copyright p {
    margin: 0;
    font-size: 0.8125rem;
    color: color-mix(in srgb, var(--color-foreground) 60%, transparent);
  }

  .footer__copyright a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* ── Localization selectors ─────────────────────────────────────────── */
  .footer__localization {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.625rem;
  }

  .footer-localization__form {
    display: flex;
    align-items: center;
  }

  .footer-localization__select-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .footer-localization__select {
    appearance: none;
    background-color: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm, 2px);
    padding: 0.375rem 2rem 0.375rem 0.75rem;
    font-family: inherit;
    font-size: 0.8125rem;
    color: color-mix(in srgb, var(--color-foreground) 70%, transparent);
    cursor: pointer;
    transition: border-color var(--transition-base, 0.25s ease);
    outline: none;
  }

  .footer-localization__select:hover,
  .footer-localization__select:focus {
    border-color: var(--color-foreground);
    color: var(--color-foreground);
  }

  .footer-localization__chevron {
    position: absolute;
    inset-inline-end: 0.5rem;
    pointer-events: none;
    color: color-mix(in srgb, var(--color-foreground) 60%, transparent);
    display: flex;
    align-items: center;
  }

  /* ── Payment icons ──────────────────────────────────────────────────── */
  .footer__payment-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.375rem;
  }

  .footer__payment-icon,
  .footer__payment-list li svg,
  .footer__payment-list li img {
    display: block;
    height: 1.5rem;
    width: auto;
    border-radius: 3px;
    opacity: 0.75;
  }

  /* ── Mobile adjustments ─────────────────────────────────────────────── */
  @media (max-width: 749px) {
    .footer__bottom-inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .footer__blocks {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 479px) {
    .footer__blocks {
      grid-template-columns: 1fr;
    }

    .footer-newsletter__field {
      flex-direction: column;
    }

    .footer-newsletter__btn {
      width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.footer.name",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:labels.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:labels.localization_header"
    },
    {
      "type": "checkbox",
      "id": "show_language_selector",
      "label": "t:labels.show_language_selector",
      "info": "t:info.show_language_selector",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_country_selector",
      "label": "t:labels.show_country_selector",
