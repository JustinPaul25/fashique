{%- liquid
  assign menu        = section.settings.menu
  assign sticky      = section.settings.sticky_header
  assign logo        = section.settings.logo
  assign logo_width  = section.settings.logo_width
  assign show_lang    = section.settings.show_language_selector
  assign show_country = section.settings.show_country_selector
  assign logo_2x      = logo_width | times: 2
  assign show_mobile_localization_footer = false
  if show_lang and localization.available_languages.size > 1
    assign show_mobile_localization_footer = true
  endif
  if show_country and localization.available_countries.size > 1
    assign show_mobile_localization_footer = true
  endif
  if logo != blank and logo.width > 0
    assign logo_height        = logo.height | times: logo_width | divided_by: logo.width | round
    assign logo_mobile_height = logo.height | times: 200      | divided_by: logo.width | round
  else
    assign logo_height        = 60
    assign logo_mobile_height = 40
  endif
-%}

<header
  id="site-header"
  class="site-header full-width color-scheme color-{{ section.settings.color_scheme }}"
  data-sticky="{{ sticky }}"
>
  <div class="site-header__inner">

    {%- comment -%} ── Logo ─────────────────────────────────────────────── {%- endcomment -%}
    <a href="{{ routes.root_url }}" class="site-header__logo" aria-label="{{ shop.name }}">
      {%- if logo != blank -%}
        <img
          src="{{ logo | image_url: width: logo_width }}"
          srcset="{{ logo | image_url: width: logo_width }} 1x, {{ logo | image_url: width: logo_2x }} 2x"
          alt="{{ logo.alt | default: shop.name }}"
          width="{{ logo_width }}"
          height="{{ logo_height }}"
          loading="eager"
          fetchpriority="high"
          class="site-header__logo-img"
        >
      {%- else -%}
        <span class="site-header__shop-name">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    {%- comment -%} ── Desktop navigation ──────────────────────────────── {%- endcomment -%}
    <nav class="site-header__nav" aria-label="{{ 'accessibility.navigation' | t }}">
      <ul class="site-header__nav-list" role="list">
        {%- for link in menu.links -%}
          {%- assign has_children = false -%}
          {%- if link.links.size > 0 -%}{%- assign has_children = true -%}{%- endif -%}

          {%- comment -%} Check whether a mega_menu block targets this nav item {%- endcomment -%}
          {%- assign mega_block = null -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'mega_menu' and block.settings.menu_item == link.title -%}
              {%- assign mega_block = block -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}

          <li class="site-header__nav-item{% if has_children %} has-dropdown{% if mega_block %} has-mega{% endif %}{% endif %}">
            <a
              href="{{ link.url }}"
              class="site-header__nav-link{% if link.active %} is-active{% endif %}"
              {% if has_children %}
                aria-haspopup="{% if mega_block %}dialog{% else %}true{% endif %}"
                aria-expanded="false"
                {% if mega_block %}data-mega-trigger="{{ link.title | handle }}"{% endif %}
              {% endif %}
            >
              {{- link.title -}}
              {%- if has_children -%}
                <span class="site-header__nav-chevron" aria-hidden="true">
                  {{- 'icon-chevron-down.svg' | inline_asset_content -}}
                </span>
              {%- endif -%}
            </a>

            {%- comment -%} Simple dropdown — only when no mega block is configured {%- endcomment -%}
            {%- if has_children and mega_block == null -%}
              <ul class="site-header__dropdown" role="list" aria-label="{{ link.title }}">
                {%- for child in link.links -%}
                  <li>
                    <a
                      href="{{ child.url }}"
                      class="site-header__dropdown-link{% if child.active %} is-active{% endif %}"
                    >{{ child.title }}</a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </nav>

    {%- comment -%} ── Header actions ───────────────────────────────────── {%- endcomment -%}
    <div class="site-header__actions">

      {%- comment -%} Search trigger {%- endcomment -%}
      <button
        type="button"
        class="site-header__icon-btn"
        aria-label="{{ 'accessibility.open_search' | t }}"
        aria-expanded="false"
        aria-controls="header-search-drawer"
        data-search-trigger
      >
        {{- 'icon-search.svg' | inline_asset_content -}}
      </button>

      {%- comment -%} Account (shopify-account web component) {%- endcomment -%}
      {%- if shop.customer_accounts_enabled -%}
        <shopify-account
          menu="{{ section.settings.customer_account_menu }}"
          class="site-header__icon-btn"
          aria-label="{{ 'accessibility.account' | t }}"
        >
          {{- 'icon-account.svg' | inline_asset_content -}}
        </shopify-account>
      {%- endif -%}

      {%- comment -%} Cart icon + live count badge {%- endcomment -%}
      <a
        href="{{ routes.cart_url }}"
        class="site-header__icon-btn site-header__cart"
        aria-label="{{ 'accessibility.cart_count' | t: count: cart.item_count }}"
      >
        {{- 'icon-cart.svg' | inline_asset_content -}}
        <span
          class="cart-badge{% if cart.item_count == 0 %} is-empty{% endif %}"
          aria-hidden="true"
        >{{ cart.item_count }}</span>
      </a>

      {%- comment -%} Language selector (desktop) {%- endcomment -%}
      {%- if show_lang and localization.available_languages.size > 1 -%}
        <details class="site-header__localization" data-localization>
          <summary class="site-header__icon-btn site-header__lang-summary">
            <span>{{ localization.language.iso_code | upcase }}</span>
            {{- 'icon-chevron-down.svg' | inline_asset_content -}}
          </summary>
          <div class="site-header__localization-panel">
            {%- form 'localization', id: 'HeaderLanguageForm' -%}
              {%- for language in localization.available_languages -%}
                <button
                  type="submit"
                  name="locale_code"
                  value="{{ language.iso_code }}"
                  class="site-header__lang-btn{% if language.iso_code == localization.language.iso_code %} is-active{% endif %}"
                >{{ language.endonym_name }}</button>
              {%- endfor -%}
            {%- endform -%}
          </div>
        </details>
      {%- endif -%}

      {%- comment -%} Country / currency selector (desktop) {%- endcomment -%}
      {%- if show_country and localization.available_countries.size > 1 -%}
        <details class="site-header__localization" data-localization>
          <summary class="site-header__icon-btn site-header__lang-summary">
            <span>{{ localization.country.currency.iso_code }}</span>
            {{- 'icon-chevron-down.svg' | inline_asset_content -}}
          </summary>
          <div class="site-header__localization-panel">
            {%- form 'localization', id: 'HeaderCountryForm' -%}
              {%- for country in localization.available_countries -%}
                <button
                  type="submit"
                  name="country_code"
                  value="{{ country.iso_code }}"
                  class="site-header__lang-btn{% if country.iso_code == localization.country.iso_code %} is-active{% endif %}"
                >{{ country.name }} ({{ country.currency.iso_code }})</button>
              {%- endfor -%}
            {%- endform -%}
          </div>
        </details>
      {%- endif -%}

      {%- comment -%} Hamburger — mobile only {%- endcomment -%}
      <button
        type="button"
        class="site-header__hamburger site-header__icon-btn"
        aria-label="{{ 'accessibility.open_menu' | t }}"
        aria-expanded="false"
        aria-controls="mobile-nav-drawer"
        data-hamburger
      >
        {{- 'icon-hamburger.svg' | inline_asset_content -}}
      </button>

    </div>
  </div>

  {%- comment -%} ── Mega menu panels ──────────────────────────────────── {%- endcomment -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'mega_menu' -%}

      {%- comment -%} Find the matching top-level nav link for its children {%- endcomment -%}
      {%- assign mega_nav_link = null -%}
      {%- for link in menu.links -%}
        {%- if link.title == block.settings.menu_item -%}
          {%- assign mega_nav_link = link -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}

      <div
        class="mega-menu"
        id="mega-menu-{{ block.settings.menu_item | handle }}"
        role="dialog"
        aria-label="{{ block.settings.menu_item }}"
        data-mega-panel="{{ block.settings.menu_item | handle }}"
        hidden
        {{ block.shopify_attributes }}
      >
        <div class="mega-menu__inner">

          {%- comment -%} Link columns from the nav tree {%- endcomment -%}
          {%- if mega_nav_link != null and mega_nav_link.links.size > 0 -%}
            <div class="mega-menu__columns">
              {%- for child in mega_nav_link.links -%}
                <div class="mega-menu__column">
                  {%- if child.links.size > 0 -%}
                    {%- comment -%} Grandchildren exist → this child is a column heading {%- endcomment -%}
                    <a
                      href="{{ child.url }}"
                      class="mega-menu__column-heading{% if child.active %} is-active{% endif %}"
                    >{{ child.title }}</a>
                    <ul class="mega-menu__column-list" role="list">
                      {%- for grandchild in child.links -%}
                        <li>
                          <a
                            href="{{ grandchild.url }}"
                            class="mega-menu__column-link{% if grandchild.active %} is-active{% endif %}"
                          >{{ grandchild.title }}</a>
                        </li>
                      {%- endfor -%}
                    </ul>
                  {%- else -%}
                    {%- comment -%} No grandchildren → flat link {%- endcomment -%}
                    <a
                      href="{{ child.url }}"
                      class="mega-menu__flat-link{% if child.active %} is-active{% endif %}"
                    >{{ child.title }}</a>
                  {%- endif -%}
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- comment -%} Optional in-menu promo image + text {%- endcomment -%}
          {%- if block.settings.promo_image != blank -%}
            {%- assign promo_h = block.settings.promo_image.height | times: 400 | divided_by: block.settings.promo_image.width | round -%}
            <div class="mega-menu__promo">
              <a
                href="{{ block.settings.promo_link | default: '#' }}"
                class="mega-menu__promo-link"
              >
                <div class="mega-menu__promo-img-wrap">
                  <img
                    src="{{ block.settings.promo_image | image_url: width: 400 }}"
                    srcset="{{ block.settings.promo_image | image_url: width: 400 }} 1x, {{ block.settings.promo_image | image_url: width: 800 }} 2x"
                    alt="{{ block.settings.promo_image.alt | default: block.settings.promo_heading }}"
                    width="400"
                    height="{{ promo_h }}"
                    loading="lazy"
                    class="mega-menu__promo-img"
                  >
                </div>
                <div class="mega-menu__promo-body">
                  {%- if block.settings.promo_heading != blank -%}
                    <p class="mega-menu__promo-heading">{{ block.settings.promo_heading }}</p>
                  {%- endif -%}
                  {%- if block.settings.promo_subheading != blank -%}
                    <p class="mega-menu__promo-subheading">{{ block.settings.promo_subheading }}</p>
                  {%- endif -%}
                  {%- if block.settings.promo_cta != blank -%}
                    <span class="mega-menu__promo-cta">{{ block.settings.promo_cta }}</span>
                  {%- endif -%}
                </div>
              </a>
            </div>
          {%- endif -%}

        </div>
      </div>
    {%- endif -%}
  {%- endfor -%}

  {%- comment -%} ── Search drawer (expands below header bar) ─────────── {%- endcomment -%}
  <div
    id="header-search-drawer"
    class="site-header__search-drawer"
    role="search"
    aria-hidden="true"
    data-search-drawer
  >
    <div class="site-header__search-inner">
      <form action="{{ routes.search_url }}" method="get" class="site-header__search-form">
        <input type="hidden" name="type" value="product,article,page">
        <label class="visually-hidden" for="HeaderSearchInput">{{ 'search.title' | t }}</label>
        <input
          id="HeaderSearchInput"
          type="search"
          name="q"
          class="site-header__search-input"
          placeholder="{{ 'search.placeholder' | t }}"
          autocomplete="off"
          data-search-input
        >
        <button type="submit" class="site-header__icon-btn" aria-label="{{ 'search.submit' | t }}">
          {{- 'icon-search.svg' | inline_asset_content -}}
        </button>
        <button
          type="button"
          class="site-header__icon-btn"
          aria-label="{{ 'accessibility.close' | t }}"
          data-search-close
        >
          {{- 'icon-close.svg' | inline_asset_content -}}
        </button>
      </form>
    </div>
  </div>
</header>

{%- comment -%}
  Spacer: holds the document-flow space occupied by the fixed-position header.
  Without this, page content would render underneath the fixed header.
  Height is kept in sync with --header-height via CSS custom property.
{%- endcomment -%}
{%- unless sticky == 'none' -%}
  <div class="site-header__spacer full-width" aria-hidden="true"></div>
{%- endunless -%}

{%- comment -%} ── Mobile nav drawer (outside header for correct stacking) {%- endcomment -%}
<div
  id="mobile-nav-drawer"
  class="mobile-nav-drawer"
  role="dialog"
  aria-modal="true"
  aria-label="{{ 'accessibility.navigation' | t }}"
  aria-hidden="true"
  data-mobile-drawer
>
  <div class="mobile-nav-drawer__overlay" data-drawer-overlay aria-hidden="true"></div>

  <div class="mobile-nav-drawer__panel">
    <div class="mobile-nav-drawer__header">
      <a href="{{ routes.root_url }}" class="mobile-nav-drawer__logo" aria-label="{{ shop.name }}">
        {%- if logo != blank -%}
          <img
            src="{{ logo | image_url: width: 200 }}"
          alt="{{ logo.alt | default: shop.name }}"
          width="200"
          height="{{ logo_mobile_height }}"
          loading="lazy"
          class="mobile-nav-drawer__logo-img"
          >
        {%- else -%}
          <span class="site-header__shop-name">{{ shop.name }}</span>
        {%- endif -%}
      </a>
      <button
        type="button"
        class="mobile-nav-drawer__close"
        aria-label="{{ 'accessibility.close_menu' | t }}"
        data-drawer-close
      >
        {{- 'icon-close.svg' | inline_asset_content -}}
      </button>
    </div>

    <nav class="mobile-nav-drawer__nav" aria-label="{{ 'accessibility.navigation' | t }}">
      <ul class="mobile-nav-drawer__list" role="list">
        {%- for link in menu.links -%}
          <li class="mobile-nav-drawer__item">
            {%- if link.links.size > 0 -%}
              <details class="mobile-nav-drawer__details">
                <summary class="mobile-nav-drawer__summary">
                  {{ link.title }}
                  {{- 'icon-chevron-down.svg' | inline_asset_content -}}
                </summary>
                <ul class="mobile-nav-drawer__sub-list" role="list">
                  {%- for child in link.links -%}
                    <li>
                      <a
                        href="{{ child.url }}"
                        class="mobile-nav-drawer__link{% if child.active %} is-active{% endif %}"
                      >{{ child.title }}</a>
                    </li>
                  {%- endfor -%}
                </ul>
              </details>
            {%- else -%}
              <a
                href="{{ link.url }}"
                class="mobile-nav-drawer__link{% if link.active %} is-active{% endif %}"
              >{{ link.title }}</a>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </nav>

    {%- if show_mobile_localization_footer -%}
      <div class="mobile-nav-drawer__footer">

        {%- if show_lang and localization.available_languages.size > 1 -%}
          {%- form 'localization', id: 'MobileLanguageForm' -%}
            <label class="mobile-nav-drawer__lang-label" for="MobileLanguageSelect">
              {{ 'accessibility.language_select' | t }}
            </label>
            <select
              id="MobileLanguageSelect"
              name="locale_code"
              data-localization-select
              class="mobile-nav-drawer__lang-select"
            >
              {%- for language in localization.available_languages -%}
                <option
                  value="{{ language.iso_code }}"
                  {% if language.iso_code == localization.language.iso_code %}selected{% endif %}
                >{{ language.endonym_name }}</option>
              {%- endfor -%}
            </select>
            <button type="submit" class="visually-hidden">{{ 'accessibility.submit' | t }}</button>
          {%- endform -%}
        {%- endif -%}

        {%- if show_country and localization.available_countries.size > 1 -%}
          {%- form 'localization', id: 'MobileCountryForm' -%}
            <label class="mobile-nav-drawer__lang-label" for="MobileCountrySelect">
              {{ 'accessibility.currency_select' | t }}
            </label>
            <select
              id="MobileCountrySelect"
              name="country_code"
              data-localization-select
              class="mobile-nav-drawer__lang-select"
            >
              {%- for country in localization.available_countries -%}
                <option
                  value="{{ country.iso_code }}"
                  {% if country.iso_code == localization.country.iso_code %}selected{% endif %}
                >{{ country.name }} ({{ country.currency.iso_code }})</option>
              {%- endfor -%}
            </select>
            <button type="submit" class="visually-hidden">{{ 'accessibility.submit' | t }}</button>
          {%- endform -%}
        {%- endif -%}

      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  /* ══════════════════════════════════════════════════════════════════════
     Site Header
     ══════════════════════════════════════════════════════════════════════ */

  /* Scroll lock when mobile nav is open */
  html:has(#mobile-nav-drawer.is-open) {
    overflow: hidden;
  }

  .site-header {
    position: relative;   /* establishes a stacking context so dropdowns clear page content */
    z-index: 200;         /* above all .shopify-section { position: relative } siblings */
    background-color: var(--color-background);
    border-bottom: 1px solid var(--color-border);
    transition:
      box-shadow var(--transition-base, 0.25s ease),
      transform 0.3s ease,
      background-color var(--transition-base, 0.25s ease);
    will-change: transform;
  }

  /* Sticky modes — position: fixed avoids the .shopify-section containing-block trap.
     --announcement-bar-height is written by component-announcement-bar.js (0px when
     no bar is present or the bar has been dismissed). */
  .site-header[data-sticky="always"],
  .site-header[data-sticky="on-scroll-up"] {
    position: fixed;
    inset-block-start: var(--announcement-bar-height, 0px);
    inset-inline: 0;
    width: 100%;
    z-index: 200;
    transition:
      box-shadow var(--transition-base, 0.25s ease),
      transform 0.3s ease,
      background-color var(--transition-base, 0.25s ease),
      inset-block-start 0.35s ease;
  }

  /* Spacer reserves document-flow space equal to the fixed header's height.
     The sibling selector keeps it in sync with the compact state via CSS only
     (no JS needed), so there is no JS ↔ CSS feedback loop. */
  .site-header__spacer {
    height: var(--header-height-base, 5rem);
    transition: height var(--transition-base, 0.25s ease);
  }

  .site-header.is-compact ~ .site-header__spacer {
    height: var(--header-height-compact, 3.75rem);
  }

  .site-header.is-scrolled {
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.07);
  }

  .site-header[data-sticky="on-scroll-up"].is-hidden {
    transform: translateY(-100%);
  }

  /* ── Inner layout ──────────────────────────────────────────────────── */
  /* Mobile: simple flex (nav is hidden, just logo ↔ actions).
     Desktop: 3-column grid so the nav is geometrically centred on the page
     regardless of the logo/actions width difference. */
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    /* Height uses --header-height-base directly — never --header-height.
       This breaks the JS-measures-border → inner-grows loop. */
    height: var(--header-height-base, 5rem);
    min-height: 3rem;
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: var(--page-margin);
    transition: height var(--transition-base, 0.25s ease);
  }

  @media (min-width: 990px) {
    .site-header__inner {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      gap: 0;
    }
  }

  .site-header.is-compact .site-header__inner {
    height: var(--header-height-compact, 3.75rem);
  }

  /* ── Logo ──────────────────────────────────────────────────────────── */
  .site-header__logo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    text-decoration: none;
    color: var(--color-foreground);
    justify-self: start; /* grid alignment on desktop */
  }

  .site-header__logo-img {
    display: block;
    height: auto;
    max-height: calc(var(--header-height-base, 5rem) - 1.75rem);
    width: auto;
    transition: max-height var(--transition-base, 0.25s ease);
  }

  .site-header.is-compact .site-header__logo-img {
    max-height: calc(var(--header-height-compact, 3.75rem) - 1.25rem);
  }

  .site-header__shop-name {
    font-family: var(--font-heading-family);
    font-size: var(--font-size-h4, 1.25rem);
    font-weight: var(--font-heading-weight);
    letter-spacing: var(--font-heading-letter-spacing, -0.02em);
    line-height: 1;
    white-space: nowrap;
  }

  /* ── Desktop navigation ────────────────────────────────────────────── */
  .site-header__nav {
    display: none;
  }

  @media (min-width: 990px) {
    .site-header__nav {
      display: flex;
      flex: 1;
      justify-content: center;
      overflow: hidden;
    }
  }

  .site-header__nav-list {
    display: flex;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0.125rem;
  }

  .site-header__nav-item {
    position: relative;
  }

  .site-header__nav-link {
    display: flex;
    align-items: center;
    gap: 0.2rem;
    padding: 0.5rem 0.875rem;
    color: var(--color-foreground);
    text-decoration: none;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: var(--radius-sm, 2px);
    white-space: nowrap;
    transition: color var(--transition-base, 0.25s ease);
  }

  .site-header__nav-link:hover,
  .site-header__nav-link.is-active {
    color: var(--color-primary);
  }

  .site-header__nav-chevron {
    display: flex;
    align-items: center;
  }

  .site-header__nav-chevron svg {
    width: 0.875rem;
    height: 0.875rem;
    transition: transform var(--transition-base, 0.25s ease);
  }

  .site-header__nav-item:hover .site-header__nav-chevron svg,
  .site-header__nav-item:focus-within .site-header__nav-chevron svg {
    transform: rotate(-180deg);
  }

  /* Dropdown */
  .site-header__dropdown {
    position: absolute;
    inset-block-start: calc(100% + 0.5rem);
    inset-inline-start: 0;
    min-width: 200px;
    list-style: none;
    margin: 0;
    padding: 0.5rem 0;
    background-color: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md, 4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-0.5rem);
    transition:
      opacity var(--transition-base, 0.25s ease),
      visibility var(--transition-base, 0.25s ease),
      transform var(--transition-base, 0.25s ease);
    z-index: 50;
  }

  .site-header__nav-item:hover .site-header__dropdown,
  .site-header__nav-item:focus-within .site-header__dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .site-header__dropdown-link {
    display: block;
    padding: 0.5625rem 1.125rem;
    color: var(--color-foreground);
    text-decoration: none;
    font-size: 0.875rem;
    white-space: nowrap;
    transition:
      color var(--transition-base, 0.25s ease),
      background-color var(--transition-base, 0.25s ease);
  }

  .site-header__dropdown-link:hover,
  .site-header__dropdown-link.is-active {
    background-color: color-mix(in srgb, var(--color-foreground) 5%, transparent);
    color: var(--color-primary);
  }

  /* ── Mega Menu ──────────────────────────────────────────────────────── */
  .mega-menu {
    display: none; /* hidden on mobile — accordion in drawer handles navigation */
  }

  @media (min-width: 990px) {
    .mega-menu {
      display: block;
      position: absolute;
      inset-inline: 0;
      top: 100%;
      background-color: var(--color-background);
      border-bottom: 1px solid var(--color-border);
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
      z-index: 50;
      animation: mega-in 0.18s ease both;
    }

    .mega-menu[hidden] {
      display: none;
    }

    @keyframes mega-in {
      from { opacity: 0; transform: translateY(-6px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .mega-menu__inner {
      display: flex;
      gap: 3rem;
      align-items: flex-start;
      max-width: var(--page-width);
      margin-inline: auto;
      padding: 2rem var(--page-margin) 2.25rem;
    }

    /* ── Columns ───────────────────────────────────────────────────────── */
    .mega-menu__columns {
      display: flex;
      flex: 1;
      flex-wrap: wrap;
      gap: 1rem 2.5rem;
    }

    .mega-menu__column {
      min-width: 130px;
    }

    .mega-menu__column-heading {
      display: block;
      font-size: 0.6875rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-foreground);
      text-decoration: none;
      padding-bottom: 0.625rem;
      margin-bottom: 0.5rem;
      border-bottom: 1px solid var(--color-border);
    }

    .mega-menu__column-heading:hover,
    .mega-menu__column-heading.is-active {
      color: var(--color-primary);
    }

    .mega-menu__column-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    .mega-menu__column-link,
    .mega-menu__flat-link {
      display: block;
      font-size: 0.9375rem;
      color: color-mix(in srgb, var(--color-foreground) 80%, transparent);
      text-decoration: none;
      padding: 0.3rem 0;
      transition: color var(--transition-base, 0.25s ease);
    }

    .mega-menu__column-link:hover,
    .mega-menu__flat-link:hover,
    .mega-menu__column-link.is-active,
    .mega-menu__flat-link.is-active {
      color: var(--color-primary);
    }

    /* ── Promo block ───────────────────────────────────────────────────── */
    .mega-menu__promo {
      flex-shrink: 0;
      width: clamp(200px, 22%, 280px);
    }

    .mega-menu__promo-link {
      display: block;
      text-decoration: none;
      color: var(--color-foreground);
    }

    .mega-menu__promo-img-wrap {
      border-radius: var(--radius-sm, 2px);
      overflow: hidden;
    }

    .mega-menu__promo-img {
      display: block;
      width: 100%;
      height: 180px;
      object-fit: cover;
      transition: transform 0.4s ease;
    }

    .mega-menu__promo-link:hover .mega-menu__promo-img {
      transform: scale(1.04);
    }

    .mega-menu__promo-body {
      padding-block-start: 0.875rem;
    }

    .mega-menu__promo-heading {
      font-family: var(--font-heading-family);
      font-weight: var(--font-heading-weight);
      font-size: 1rem;
      margin: 0 0 0.25rem;
      letter-spacing: var(--font-heading-letter-spacing, -0.02em);
    }

    .mega-menu__promo-subheading {
      font-size: 0.875rem;
      color: color-mix(in srgb, var(--color-foreground) 60%, transparent);
      margin: 0 0 0.75rem;
    }

    .mega-menu__promo-cta {
      display: inline-block;
      font-size: 0.8125rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--color-primary);
      border-bottom: 1px solid currentcolor;
      padding-bottom: 0.125rem;
      transition: opacity var(--transition-base, 0.25s ease);
    }

    .mega-menu__promo-link:hover .mega-menu__promo-cta {
      opacity: 0.7;
    }
  }

  /* ── Header actions ────────────────────────────────────────────────── */
  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 0.125rem;
    flex-shrink: 0;
    justify-self: end; /* grid alignment on desktop */
  }

  .site-header__icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    padding: 0;
    background: none;
    border: none;
    border-radius: var(--radius-sm, 2px);
    color: var(--color-foreground);
    cursor: pointer;
    text-decoration: none;
    transition:
      color var(--transition-base, 0.25s ease),
      background-color var(--transition-base, 0.25s ease);
  }

  .site-header__icon-btn:hover {
    color: var(--color-primary);
    background-color: color-mix(in srgb, var(--color-foreground) 6%, transparent);
  }

  .site-header__icon-btn:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .site-header__icon-btn svg {
    width: 1.375rem;
    height: 1.375rem;
    pointer-events: none;
  }

  /* Cart badge */
  .site-header__cart {
    position: relative;
  }

  .cart-badge {
    position: absolute;
    inset-block-start: 0.3rem;
    inset-inline-end: 0.2rem;
    min-width: 1.0625rem;
    height: 1.0625rem;
    padding: 0 0.25rem;
    background-color: var(--color-primary);
    color: var(--color-background);
    font-size: 0.6rem;
    font-weight: 700;
    line-height: 1.0625rem;
    text-align: center;
    border-radius: 999px;
    transition:
      transform var(--transition-base, 0.25s ease),
      opacity var(--transition-base, 0.25s ease);
  }

  .cart-badge.is-empty {
    transform: scale(0);
    opacity: 0;
  }

  /* Hide hamburger on desktop */
  .site-header__hamburger {
    display: flex;
  }

  @media (min-width: 990px) {
    .site-header__hamburger {
      display: none;
    }
  }

  /* ── Language selector ─────────────────────────────────────────────── */
  .site-header__localization {
    position: relative;
    display: none;
  }

  @media (min-width: 990px) {
    .site-header__localization {
      display: block;
    }
  }

  .site-header__lang-summary {
    list-style: none;
    gap: 0.25rem;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    width: auto;
    padding-inline: 0.625rem;
  }

  .site-header__lang-summary::-webkit-details-marker { display: none; }

  .site-header__lang-summary svg {
    width: 0.875rem;
    height: 0.875rem;
    transition: transform var(--transition-base, 0.25s ease);
  }

  .site-header__localization[open] .site-header__lang-summary svg {
    transform: rotate(-180deg);
  }

  .site-header__localization-panel {
    position: absolute;
    inset-block-start: calc(100% + 0.5rem);
    inset-inline-end: 0;
    min-width: 150px;
    background-color: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md, 4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
    padding: 0.375rem;
    z-index: 50;
  }

  .site-header__lang-btn {
    display: block;
    width: 100%;
    padding: 0.5rem 0.75rem;
    background: none;
    border: none;
    border-radius: var(--radius-sm, 2px);
    color: var(--color-foreground);
    font-size: 0.875rem;
    text-align: start;
    cursor: pointer;
    transition:
      background-color var(--transition-base, 0.25s ease),
      color var(--transition-base, 0.25s ease);
  }

  .site-header__lang-btn:hover,
  .site-header__lang-btn.is-active {
    background-color: color-mix(in srgb, var(--color-foreground) 6%, transparent);
    color: var(--color-primary);
  }

  /* ── Search drawer ─────────────────────────────────────────────────── */
  .site-header__search-drawer {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition:
      max-height 0.3s ease,
      opacity var(--transition-base, 0.25s ease);
  }

  .site-header__search-drawer[aria-hidden="false"] {
    max-height: 5.5rem;
    opacity: 1;
    border-top: 1px solid var(--color-border);
  }

  .site-header__search-inner {
    max-width: var(--page-width);
    margin-inline: auto;
    padding: 0.875rem var(--page-margin);
  }

  .site-header__search-form {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    background-color: color-mix(in srgb, var(--color-foreground) 5%, transparent);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md, 4px);
    padding-inline: 0.375rem;
  }

  .site-header__search-input {
    flex: 1;
    height: 3rem;
    background: none;
    border: none;
    color: var(--color-foreground);
    font-size: 1rem;
    outline: none;
    padding-inline: 0.5rem;
  }

  .site-header__search-input::placeholder {
    color: color-mix(in srgb, var(--color-foreground) 45%, transparent);
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header,
    .site-header__search-drawer {
      transition: none;
    }
  }

  /* ══════════════════════════════════════════════════════════════════════
     Mobile Nav Drawer
     ══════════════════════════════════════════════════════════════════════ */
  .mobile-nav-drawer {
    position: fixed;
    inset: 0;
    z-index: 200;
    visibility: hidden;
    pointer-events: none;
  }

  .mobile-nav-drawer.is-open {
    visibility: visible;
    pointer-events: auto;
  }

  .mobile-nav-drawer__overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.45);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .mobile-nav-drawer.is-open .mobile-nav-drawer__overlay {
    opacity: 1;
  }

  .mobile-nav-drawer__panel {
    position: absolute;
    inset-block: 0;
    inset-inline-start: 0;
    display: flex;
    flex-direction: column;
    width: min(85vw, 360px);
    background-color: var(--color-background);
    color: var(--color-foreground);
    border-inline-end: 1px solid var(--color-border);
    box-shadow: 4px 0 24px rgba(0, 0, 0, 0.1);
    overflow-y: auto;
    overscroll-behavior: contain;
    transform: translateX(-100%);
    transition: transform 0.3s ease;
  }

  [dir="rtl"] .mobile-nav-drawer__panel {
    inset-inline-start: auto;
    inset-inline-end: 0;
    transform: translateX(100%);
    border-inline-end: none;
    border-inline-start: 1px solid var(--color-border);
  }

  .mobile-nav-drawer.is-open .mobile-nav-drawer__panel {
    transform: translateX(0);
  }

  .mobile-nav-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.125rem var(--page-margin);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    background-color: var(--color-background);
    z-index: 1;
  }

  .mobile-nav-drawer__logo {
    text-decoration: none;
    color: var(--color-foreground);
  }

  .mobile-nav-drawer__logo-img {
    max-height: 2rem;
    width: auto;
  }

  .mobile-nav-drawer__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    padding: 0;
    background: none;
    border: none;
    border-radius: var(--radius-sm, 2px);
    color: var(--color-foreground);
    cursor: pointer;
    transition: background-color var(--transition-base, 0.25s ease);
    flex-shrink: 0;
  }

  .mobile-nav-drawer__close:hover {
    background-color: color-mix(in srgb, var(--color-foreground) 6%, transparent);
  }

  .mobile-nav-drawer__close:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .mobile-nav-drawer__close svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  .mobile-nav-drawer__nav {
    padding-block: 0.375rem;
  }

  .mobile-nav-drawer__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .mobile-nav-drawer__item {
    border-bottom: 1px solid color-mix(in srgb, var(--color-border) 60%, transparent);
  }

  .mobile-nav-drawer__link {
    display: flex;
    align-items: center;
    padding: 0.9375rem var(--page-margin);
    color: var(--color-foreground);
    text-decoration: none;
    font-size: 1rem;
    font-weight: 500;
    transition:
      color var(--transition-base, 0.25s ease),
      background-color var(--transition-base, 0.25s ease);
  }

  .mobile-nav-drawer__link:hover,
  .mobile-nav-drawer__link.is-active {
    color: var(--color-primary);
    background-color: color-mix(in srgb, var(--color-foreground) 4%, transparent);
  }

  .mobile-nav-drawer__details {
    width: 100%;
  }

  .mobile-nav-drawer__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.9375rem var(--page-margin);
    color: var(--color-foreground);
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    list-style: none;
    user-select: none;
    transition: color var(--transition-base, 0.25s ease);
  }

  .mobile-nav-drawer__summary::-webkit-details-marker { display: none; }

  .mobile-nav-drawer__summary:hover {
    color: var(--color-primary);
  }

  .mobile-nav-drawer__summary svg {
    width: 1.125rem;
    height: 1.125rem;
    flex-shrink: 0;
    transition: transform var(--transition-base, 0.25s ease);
  }

  .mobile-nav-drawer__details[open] > .mobile-nav-drawer__summary svg {
    transform: rotate(-180deg);
  }

  .mobile-nav-drawer__sub-list {
    list-style: none;
    margin: 0;
    padding: 0.25rem 0 0.5rem;
    background-color: color-mix(in srgb, var(--color-foreground) 3%, transparent);
  }

  .mobile-nav-drawer__sub-list .mobile-nav-drawer__link {
    padding-inline-start: calc(var(--page-margin) + 1.25rem);
    font-size: 0.9375rem;
    font-weight: 400;
  }

  .mobile-nav-drawer__footer {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 1.25rem var(--page-margin);
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .mobile-nav-drawer__lang-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-foreground) 60%, transparent);
    margin-bottom: 0.5rem;
  }

  .mobile-nav-drawer__lang-select {
    width: 100%;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm, 2px);
    background-color: var(--color-background);
    color: var(--color-foreground);
    font-size: 0.875rem;
    cursor: pointer;
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-nav-drawer__overlay,
    .mobile-nav-drawer__panel {
      transition: none;
    }
  }

  /* ── Visually hidden utility ───────────────────────────────────────── */
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
{% endstylesheet %}

<script src="{{ 'section-header.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "header",
      "content": "t:labels.logo_header"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "t:labels.logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 60,
      "max": 280,
      "step": 10,
      "unit": "px",
      "label": "t:labels.logo_width",
      "info": "t:info.logo_width",
      "default": 140
    },
    {
      "type": "header",
      "content": "t:labels.navigation"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "t:labels.behavior"
    },
    {
      "type": "select",
      "id": "sticky_header",
      "label": "t:labels.sticky_header",
      "info": "t:info.sticky_header",
      "options": [
        { "value": "none",         "label": "t:options.sticky_header.none" },
        { "value": "always",       "label": "t:options.sticky_header.always" },
        { "value": "on-scroll-up", "label": "t:options.sticky_header.on_scroll_up" }
      ],
      "default": "on-scroll-up"
    },
    {
      "type": "header",
      "content": "t:labels.appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:labels.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:labels.account_and_localization"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    },
    {
      "type": "checkbox",
      "id": "show_language_selector",
      "label": "t:labels.show_language_selector",
      "info": "t:info.show_language_selector",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_country_selector",
      "label": "t:labels.show_country_selector",
      "info": "t:info.show_country_selector",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "mega_menu",
      "name": "t:blocks.mega_menu.name",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "menu_item",
          "label": "t:blocks.mega_menu.settings.menu_item.label",
          "info": "t:blocks.mega_menu.settings.menu_item.info"
        },
        {
          "type": "header",
          "content": "t:blocks.mega_menu.settings.promo_header.content"
        },
        {
          "type": "image_picker",
          "id": "promo_image",
          "label": "t:blocks.mega_menu.settings.promo_image.label"
        },
        {
          "type": "text",
          "id": "promo_heading",
          "label": "t:blocks.mega_menu.settings.promo_heading.label"
        },
        {
          "type": "text",
          "id": "promo_subheading",
          "label": "t:blocks.mega_menu.settings.promo_subheading.label"
        },
        {
          "type": "url",
          "id": "promo_link",
          "label": "t:blocks.mega_menu.settings.promo_link.label"
        },
        {
          "type": "text",
          "id": "promo_cta",
          "label": "t:blocks.mega_menu.settings.promo_cta.label",
          "default": "Shop now"
        }
      ]
    }
  ]
}
{% endschema %}
