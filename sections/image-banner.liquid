{%- comment -%}
  Image Banner  (Phase 5.1)
  ──────────────────────────
  • Full-width editorial image with overlay text, heading, and CTA button.
  • Optional mobile-specific image.
  • Overlay opacity, text position, and banner height are all schema-driven.
{%- endcomment -%}

{%- liquid
  assign overlay_alpha = section.settings.overlay_opacity | divided_by: 100.0
  assign banner_height = section.settings.height | default: settings.homepage_default_hero_height | default: 'medium'
-%}
{%- render 'section-spacing', section: section -%}

<section
  class="image-banner image-banner--{{ banner_height }} color-scheme color-{{ section.settings.color_scheme }}"
  data-section-id="{{ section.id }}"
>
  {%- comment -%} Background images {%- endcomment -%}
  <div class="image-banner__bg">
    {%- if section.settings.mobile_image != blank -%}
      {%- render 'image',
        image: section.settings.mobile_image,
        widths: '375,750',
        sizes: '100vw',
        alt: section.settings.mobile_image.alt | default: section.settings.heading,
        class: 'image-banner__bg-img image-banner__bg-img--mobile',
        loading: 'lazy',
        placeholder_type: 'lifestyle-2'
      -%}
    {%- endif -%}
    {%- render 'image',
      image: section.settings.image,
      widths: '750,1100,1500,1780,2000',
      sizes: '100vw',
      alt: section.settings.image.alt | default: section.settings.heading,
      class: 'image-banner__bg-img image-banner__bg-img--desktop',
      loading: 'lazy',
      placeholder_type: 'lifestyle-1'
    -%}
  </div>

  {%- comment -%} Overlay {%- endcomment -%}
  <div
    class="image-banner__overlay"
    style="--overlay-alpha: {{ overlay_alpha }}"
    aria-hidden="true"
  ></div>

  {%- comment -%} Content {%- endcomment -%}
  {%- if section.settings.heading != blank or section.settings.text != blank or section.settings.button_label != blank -%}
    <div class="image-banner__content image-banner__content--{{ section.settings.text_position }}">
      <div class="image-banner__inner">
        {%- if section.settings.heading != blank -%}
          <h2 class="image-banner__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <p class="image-banner__text">{{ section.settings.text | escape }}</p>
        {%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a
            href="{{ section.settings.button_url | default: '#' }}"
            class="image-banner__cta btn btn--solid"
          >
            {{ section.settings.button_label | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

</section>

{% stylesheet %}
  /* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
     IMAGE BANNER
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

  .image-banner {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: stretch;
  }

  /* Height variants */
  .image-banner--small  { min-height: clamp(16rem, 35svh, 28rem); }
  .image-banner--medium { min-height: clamp(22rem, 55svh, 44rem); }
  .image-banner--large  { min-height: clamp(28rem, 75svh, 60rem); }
  .image-banner--full   { min-height: 100svh; }

  /* Background */
  .image-banner__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .image-banner__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .image-banner__bg .image-placeholder {
    position: absolute;
    inset: 0;
  }

  .image-banner__bg .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Mobile / desktop image swap */
  .image-banner__bg-img--mobile  { display: none; }
  .image-banner__bg-img--desktop { display: block; }

  @media (max-width: 767px) {
    .image-banner__bg-img--mobile  { display: block; }
    .image-banner__bg-img--desktop { display: none; }
  }

  /* Overlay */
  .image-banner__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background-color: rgba(0, 0, 0, var(--overlay-alpha, 0.3));
    pointer-events: none;
  }

  /* Content */
  .image-banner__content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: var(--page-margin, 1.25rem);
    padding-block: var(--spacing-2xl, 5rem);
    color: #fff;
    display: flex;
    align-items: center;
  }

  .image-banner__content--left   { justify-content: flex-start; text-align: start; }
  .image-banner__content--center { justify-content: center;     text-align: center; }
  .image-banner__content--right  { justify-content: flex-end;   text-align: end; }

  .image-banner__inner {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md, 1.5rem);
    max-width: 36rem;
  }

  .image-banner__content--center .image-banner__inner { align-items: center; }
  .image-banner__content--right  .image-banner__inner { align-items: flex-end; }

  .image-banner__heading {
    font-size: var(--font-size-h1);
    font-family: var(--font-heading-family);
    font-weight: var(--font-heading-weight);
    letter-spacing: var(--font-heading-letter-spacing, -0.02em);
    line-height: var(--font-heading-line-height, 1.1);
    color: inherit;
    margin: 0;
  }

  .image-banner__text {
    font-size: clamp(1rem, 2vw, 1.125rem);
    line-height: 1.6;
    opacity: 0.9;
    margin: 0;
  }

  .image-banner__cta {
    align-self: flex-start;
  }

  .image-banner__content--center .image-banner__cta { align-self: center; }
  .image-banner__content--right  .image-banner__cta { align-self: flex-end; }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.image_banner.name",
  "tag": "section",
  "class": "section-image-banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.image_banner.settings.image.label"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "t:sections.image_banner.settings.mobile_image.label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.image_banner.settings.heading.label",
      "default": "Editorial Heading"
    },
    {
      "type": "text",
      "id": "text",
      "label": "t:sections.image_banner.settings.text.label",
      "default": "A short, evocative description of your campaign or collection."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.image_banner.settings.button_label.label",
      "default": "Shop the collection"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "t:sections.image_banner.settings.button_url.label"
    },
    {
      "type": "select",
      "id": "text_position",
      "label": "t:sections.image_banner.settings.text_position.label",
      "options": [
        { "value": "left",   "label": "t:options.text_position.left" },
        { "value": "center", "label": "t:options.text_position.center" },
        { "value": "right",  "label": "t:options.text_position.right" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "t:sections.image_banner.settings.overlay_opacity.label",
      "info": "t:sections.image_banner.settings.overlay_opacity.info",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 30
    },
    {
      "type": "select",
      "id": "height",
      "label": "t:sections.image_banner.settings.height.label",
      "options": [
        { "value": "small",  "label": "t:options.size.small" },
        { "value": "medium", "label": "t:options.size.medium" },
        { "value": "large",  "label": "t:options.size.large" },
        { "value": "full",   "label": "t:options.size.full" }
      ],
      "default": "medium"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:labels.color_scheme",
      "default": "scheme-2"
    },
    {
      "type": "select",
      "id": "section_spacing",
      "label": "t:labels.section_spacing",
      "info": "t:info.section_spacing",
      "options": [
        { "value": "default", "label": "t:options.section_spacing.default" },
        { "value": "none",    "label": "t:options.section_spacing.none"    },
        { "value": "xs",      "label": "t:options.section_spacing.xs"      },
        { "value": "sm",      "label": "t:options.section_spacing.sm"      },
        { "value": "md",      "label": "t:options.section_spacing.md"      },
        { "value": "lg",      "label": "t:options.section_spacing.lg"      },
        { "value": "xl",      "label": "t:options.section_spacing.xl"      }
      ],
      "default": "none"
    }
  ],
  "presets": [
    {
      "name": "t:sections.image_banner.name",
      "settings": {
        "heading": "Bold statement. Pure style.",
        "text": "Discover the collection.",
        "button_label": "Shop now",
        "text_position": "left",
        "overlay_opacity": 30,
        "height": "medium"
      }
    }
  ]
}
{% endschema %}
