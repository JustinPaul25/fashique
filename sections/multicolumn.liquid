{%- comment -%}
  Multicolumn  (Phase 5.1)
  ─────────────────────────
  • 2–4 equal columns, each with an optional image/icon, heading, body text, and CTA.
  • Column count and content alignment are schema-driven.
  • Stacks to a single column on small screens.
{%- endcomment -%}

{%- assign col_count = section.blocks | size -%}

{%- render 'section-spacing', section: section -%}
<section
  class="multicolumn section-padding color-scheme color-{{ section.settings.color_scheme }}"
  data-section-id="{{ section.id }}"
>
  <div class="page-width">

    {%- if section.settings.title != blank -%}
      <h2 class="multicolumn__title section-heading">{{ section.settings.title | escape }}</h2>
    {%- endif -%}

    {%- if col_count > 0 -%}
      <ul
        class="multicolumn__grid multicolumn__grid--{{ section.settings.columns_desktop }} list-unstyled"
        role="list"
        style="--col-count: {{ section.settings.columns_desktop }}"
      >
        {%- for block in section.blocks -%}
          {%- assign col_placeholder_num = forloop.index | modulo: 6 | plus: 1 -%}
          {%- assign col_placeholder = 'collection-' | append: col_placeholder_num -%}
          <li
            class="multicolumn__item multicolumn__item--{{ section.settings.alignment }}"
            {{ block.shopify_attributes }}
          >
            <div class="multicolumn__media">
              {%- render 'image',
                image: block.settings.image,
                widths: '200,400,600',
                sizes: '(min-width: 1024px) 25vw, (min-width: 640px) 50vw, 100vw',
                alt: block.settings.image.alt | default: block.settings.heading,
                class: 'multicolumn__img',
                placeholder_type: col_placeholder
              -%}
            </div>

            {%- if block.settings.heading != blank -%}
              <h3 class="multicolumn__item-heading">{{ block.settings.heading | escape }}</h3>
            {%- endif -%}

            {%- if block.settings.text != blank -%}
              <div class="multicolumn__item-text rte">{{ block.settings.text }}</div>
            {%- endif -%}

            {%- if block.settings.button_label != blank and block.settings.button_url != blank -%}
              <a
                href="{{ block.settings.button_url }}"
                class="multicolumn__item-cta btn btn--outline btn--sm"
              >
                {{- block.settings.button_label | escape -}}
              </a>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>

    {%- elsif request.design_mode -%}
      <p class="multicolumn__empty-hint">Add column blocks to this section.</p>
    {%- endif -%}

  </div>
</section>

{% stylesheet %}
  /* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
     MULTICOLUMN
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

  .multicolumn {
    background-color: var(--color-background);
    color: var(--color-foreground);
    padding-block: var(--section-padding-block);
  }

  .multicolumn__title {
    font-size: var(--font-size-h2);
    font-family: var(--font-heading-family);
    font-weight: var(--font-heading-weight);
    letter-spacing: var(--font-heading-letter-spacing, -0.02em);
    line-height: var(--font-heading-line-height, 1.1);
    margin: 0 0 var(--spacing-xl);
  }

  /* ── Grid ────────────────────────────────────────────────────────── */
  .multicolumn__grid {
    display: grid;
    gap: var(--spacing-xl);
    padding: 0;
    margin: 0;
  }

  .multicolumn__grid--2 { grid-template-columns: repeat(2, 1fr); }
  .multicolumn__grid--3 { grid-template-columns: repeat(3, 1fr); }
  .multicolumn__grid--4 { grid-template-columns: repeat(4, 1fr); }

  @media (max-width: 1024px) {
    .multicolumn__grid--4 { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .multicolumn__grid--3 { grid-template-columns: repeat(2, 1fr); }
    .multicolumn__grid--4 { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .multicolumn__grid--2,
    .multicolumn__grid--3,
    .multicolumn__grid--4 { grid-template-columns: 1fr; }
  }

  /* ── Column item ─────────────────────────────────────────────────── */
  .multicolumn__item {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .multicolumn__item--center {
    align-items: center;
    text-align: center;
  }

  .multicolumn__item--right {
    align-items: flex-end;
    text-align: end;
  }

  /* ── Media ───────────────────────────────────────────────────────── */
  .multicolumn__media {
    width: 100%;
    overflow: hidden;
    border-radius: var(--radius-sm);
    aspect-ratio: 1 / 1;
    max-width: 12rem;
    background-color: #F4F6F8;
  }

  .multicolumn__media .image-placeholder {
    width: 100%;
    height: 100%;
  }

  .multicolumn__item--center .multicolumn__media { margin-inline: auto; }
  .multicolumn__item--right  .multicolumn__media { margin-inline-start: auto; }

  .multicolumn__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--transition-base);
  }

  .multicolumn__item:hover .multicolumn__img { transform: scale(1.03); }

  /* ── Text ────────────────────────────────────────────────────────── */
  .multicolumn__item-heading {
    font-size: var(--font-size-h4);
    font-family: var(--font-heading-family);
    font-weight: var(--font-heading-weight);
    letter-spacing: var(--font-heading-letter-spacing, -0.02em);
    line-height: 1.2;
    margin: 0;
  }

  .multicolumn__item-text {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: color-mix(in srgb, var(--color-foreground) 75%, transparent);
    margin: 0;
  }

  /* ── Placeholder ─────────────────────────────────────────────────── */
  .multicolumn__empty-hint {
    opacity: 0.5;
    font-size: 0.875rem;
    text-align: center;
    padding-block: var(--spacing-xl);
  }

  @media (prefers-reduced-motion: reduce) {
    .multicolumn__item:hover .multicolumn__img { transform: none; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.multicolumn.name",
  "tag": "section",
  "class": "section-multicolumn",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "t:sections.multicolumn.settings.title.label",
      "default": "Why choose us"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "t:sections.multicolumn.settings.columns_desktop.label",
      "options": [
        { "value": "2", "label": "t:options.columns.two" },
        { "value": "3", "label": "t:options.columns.three" },
        { "value": "4", "label": "t:options.columns.four" }
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "t:sections.multicolumn.settings.alignment.label",
      "options": [
        { "value": "left",   "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" },
        { "value": "right",  "label": "t:options.alignment.right" }
      ],
      "default": "left"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:labels.color_scheme",
      "default": "scheme-3"
    },
    {
      "type": "select",
      "id": "section_spacing",
      "label": "t:labels.section_spacing",
      "info": "t:info.section_spacing",
      "options": [
        { "value": "default", "label": "t:options.section_spacing.default" },
        { "value": "none",    "label": "t:options.section_spacing.none"    },
        { "value": "xs",      "label": "t:options.section_spacing.xs"      },
        { "value": "sm",      "label": "t:options.section_spacing.sm"      },
        { "value": "md",      "label": "t:options.section_spacing.md"      },
        { "value": "lg",      "label": "t:options.section_spacing.lg"      },
        { "value": "xl",      "label": "t:options.section_spacing.xl"      }
      ],
      "default": "default"
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "t:blocks.column.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:blocks.column.settings.image.label"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:blocks.column.settings.heading.label",
          "default": "Column heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "t:blocks.column.settings.text.label",
          "default": "<p>Pair this text with an image to focus on your chosen product, collection, or blog post.</p>"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "t:blocks.column.settings.button_label.label"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "t:blocks.column.settings.button_url.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.multicolumn.name",
      "settings": { "columns_desktop": "3", "alignment": "center" },
      "blocks": [
        {
          "type": "column",
          "settings": {
            "heading": "Free shipping",
            "text": "<p>Complimentary shipping on all orders over $100.</p>"
          }
        },
        {
          "type": "column",
          "settings": {
            "heading": "Easy returns",
            "text": "<p>Hassle-free returns within 30 days of purchase.</p>"
          }
        },
        {
          "type": "column",
          "settings": {
            "heading": "Secure checkout",
            "text": "<p>Your payment is protected with industry-leading encryption.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
