{%- comment -%}
  Password page (Phase 5.10): branding, storefront password form, optional newsletter.
{%- endcomment -%}

{%- render 'section-spacing', section: section -%}

<div class="password-page section-padding color-scheme color-{{ section.settings.color_scheme }}">
  <div class="password-page__inner page-width">
    <div class="password-page__brand">
      {%- if section.settings.logo != blank -%}
        <div class="password-page__logo">
          {{
            section.settings.logo
            | image_url: width: 400
            | image_tag:
              alt: shop.name,
              loading: 'eager',
              class: 'password-page__logo-img',
              widths: '200,400',
              sizes: '(max-width: 400px) 200px, 400px'
          }}
        </div>
      {%- elsif settings.logo != blank -%}
        <div class="password-page__logo">
          {{
            settings.logo
            | image_url: width: 400
            | image_tag:
              alt: shop.name,
              loading: 'eager',
              class: 'password-page__logo-img',
              widths: '200,400',
              sizes: '(max-width: 400px) 200px, 400px'
          }}
        </div>
      {%- else -%}
        <p class="password-page__shop-name">{{ shop.name | escape }}</p>
      {%- endif -%}
    </div>

    <h1 class="password-page__title">
      {%- if section.settings.heading != blank -%}
        {{- section.settings.heading | escape -}}
      {%- else -%}
        {{- 'password.title' | t -}}
      {%- endif -%}
    </h1>

    {%- if section.settings.subheading != blank -%}
      <p class="password-page__subheading">{{ section.settings.subheading | escape }}</p>
    {%- endif -%}

    {%- if shop.password_message != blank -%}
      <div class="password-page__message rte">{{ shop.password_message }}</div>
    {%- endif -%}

    {%- assign pw_form_id = 'password-form-' | append: section.id -%}
    {%- form 'storefront_password', id: pw_form_id, class: 'password-page__form' -%}
      {%- if form.errors -%}
        <div class="password-page__errors" role="alert">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <label class="password-page__label" for="password-input-{{ section.id }}">
        {{- 'password.password' | t -}}
      </label>
      <div class="password-page__row">
        <input
          type="password"
          name="password"
          id="password-input-{{ section.id }}"
          class="password-page__input"
          autocomplete="current-password"
          required
        >
        <button type="submit" class="btn btn--solid password-page__submit">
          {{- 'password.enter' | t -}}
        </button>
      </div>
    {%- endform -%}

    {%- if section.settings.show_newsletter -%}
      <div class="password-page__newsletter">
        <h2 class="password-page__newsletter-heading">{{ 'password.newsletter_heading' | t }}</h2>
        <p class="password-page__newsletter-text">{{ 'password.newsletter_text' | t }}</p>

        {%- assign nl_form_id = 'password-newsletter-' | append: section.id -%}
        {%- form 'customer', id: nl_form_id, class: 'password-page__nl-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">

          {%- if form.posted_successfully? -%}
            <p class="password-page__nl-success" role="status">{{ 'footer.newsletter.success' | t }}</p>
          {%- else -%}
            <div class="password-page__nl-row">
              <label class="visually-hidden" for="password-nl-email-{{ section.id }}">
                {{- 'footer.newsletter.email_placeholder' | t -}}
              </label>
              <input
                type="email"
                id="password-nl-email-{{ section.id }}"
                class="password-page__nl-input"
                name="contact[email]"
                autocomplete="email"
                placeholder="{{ 'footer.newsletter.email_placeholder' | t }}"
                required
              >
              <button type="submit" class="btn btn--outline password-page__nl-btn">
                {{- 'footer.newsletter.submit' | t -}}
              </button>
            </div>
            {%- if form.errors -%}
              <p class="password-page__nl-error" role="alert">{{ 'sections.email_signup.error' | t }}</p>
            {%- endif -%}
          {%- endif -%}
        {%- endform -%}
      </div>
    {%- endif -%}

    <p class="password-page__admin">
      <a href="{{ shop.url }}/admin">{{ 'password.admin_link' | t }}</a>
    </p>
  </div>
</div>

{% stylesheet %}
  .password-page__inner {
    max-width: 28rem;
    margin-inline: auto;
    text-align: center;
    padding-block: var(--spacing-xl);
  }

  .password-page__logo-img {
    max-width: 200px;
    height: auto;
    margin-inline: auto;
  }

  .password-page__shop-name {
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0 0 var(--spacing-md);
  }

  .password-page__title {
    font-size: clamp(1.5rem, 4vw, 2rem);
    margin: 0 0 var(--spacing-sm);
  }

  .password-page__subheading {
    margin: 0 0 var(--spacing-md);
    opacity: 0.85;
  }

  .password-page__message {
    margin-bottom: var(--spacing-lg);
    text-align: start;
  }

  .password-page__form {
    text-align: start;
    margin-bottom: var(--spacing-xl);
  }

  .password-page__label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: var(--spacing-xs);
  }

  .password-page__row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
  }

  .password-page__input {
    flex: 1 1 10rem;
    min-width: 0;
    min-height: 3rem;
    padding: 0 0.75rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    background: var(--color-background);
    color: inherit;
    font: inherit;
  }

  .password-page__submit {
    min-height: 3rem;
  }

  .password-page__errors {
    margin-bottom: var(--spacing-sm);
  }

  .password-page__newsletter {
    padding-top: var(--spacing-xl);
    border-top: 1px solid var(--color-border);
    text-align: start;
  }

  .password-page__newsletter-heading {
    font-size: 1.125rem;
    margin: 0 0 var(--spacing-xs);
  }

  .password-page__newsletter-text {
    font-size: 0.875rem;
    opacity: 0.85;
    margin: 0 0 var(--spacing-md);
  }

  .password-page__nl-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
  }

  .password-page__nl-input {
    flex: 1 1 12rem;
    min-width: 0;
    min-height: 3rem;
    padding: 0 0.75rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    background: var(--color-background);
    color: inherit;
    font: inherit;
  }

  .password-page__nl-btn {
    min-height: 3rem;
  }

  .password-page__nl-success {
    color: inherit;
    margin: 0;
  }

  .password-page__nl-error {
    margin: var(--spacing-xs) 0 0;
    font-size: 0.875rem;
  }

  .password-page__admin {
    margin-top: var(--spacing-xl);
    font-size: 0.8125rem;
    opacity: 0.65;
  }

  .password-page__admin a {
    color: inherit;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.password.name",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:labels.color_scheme",
      "default": "scheme-3"
    },
    {
      "type": "select",
      "id": "section_spacing",
      "label": "t:labels.section_spacing",
      "info": "t:info.section_spacing",
      "options": [
        { "value": "default", "label": "t:options.section_spacing.default" },
        { "value": "none", "label": "t:options.section_spacing.none" },
        { "value": "xs", "label": "t:options.section_spacing.xs" },
        { "value": "sm", "label": "t:options.section_spacing.sm" },
        { "value": "md", "label": "t:options.section_spacing.md" },
        { "value": "lg", "label": "t:options.section_spacing.lg" },
        { "value": "xl", "label": "t:options.section_spacing.xl" }
      ],
      "default": "xl"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "t:sections.password.settings.logo.label",
      "info": "t:sections.password.settings.logo.info"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.password.settings.heading.label",
      "default": "Opening soon"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:sections.password.settings.subheading.label"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "t:sections.password.settings.show_newsletter.label",
      "default": true
    }
  ]
}
{% endschema %}
