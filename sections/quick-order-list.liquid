{%- comment -%}
  Quick order list (Phase 6.6): table of products from a collection; batch add via Cart API.
{%- endcomment -%}

{%- liquid
  assign qol_collection = section.settings.collection
  assign limit = section.settings.products_limit | default: 20
  if limit > 50
    assign limit = 50
  endif
  if limit < 1
    assign limit = 1
  endif
-%}

{%- render 'section-spacing', section: section -%}
<section
  class="quick-order-list section-padding color-scheme color-{{ section.settings.color_scheme }}"
  id="shopify-section-{{ section.id }}"
  data-qol-root
  data-qol-select-msg="{{ 'sections.quick_order_list.select_quantity' | t | escape }}"
  data-qol-error-msg="{{ 'sections.quick_order_list.add_error' | t | escape }}"
>
  <div class="page-width">
    {%- if section.settings.title != blank -%}
      <h2 class="quick-order-list__title">{{ section.settings.title | escape }}</h2>
    {%- endif -%}

    {%- if qol_collection == blank -%}
      <p class="quick-order-list__empty">{{ 'sections.quick_order_list.empty_collection' | t }}</p>
    {%- else -%}
      {%- paginate qol_collection.products by limit -%}
        {%- if qol_collection.products_count == 0 -%}
          <p class="quick-order-list__empty">{{ 'sections.quick_order_list.no_products' | t }}</p>
        {%- else -%}
          <form class="quick-order-list__form" data-qol-form novalidate>
            <div class="quick-order-list__table-wrap">
              <table class="quick-order-list__table">
                <thead>
                  <tr>
                    <th class="quick-order-list__th quick-order-list__th--media" scope="col"></th>
                    <th class="quick-order-list__th" scope="col">{{ 'sections.quick_order_list.product' | t }}</th>
                    <th class="quick-order-list__th" scope="col">{{ 'sections.quick_order_list.variant' | t }}</th>
                    <th class="quick-order-list__th" scope="col">{{ 'sections.quick_order_list.price' | t }}</th>
                    <th class="quick-order-list__th" scope="col">{{ 'products.product.quantity' | t }}</th>
                  </tr>
                </thead>
                <tbody>
                  {%- for product in qol_collection.products -%}
                    {%- assign first_v = product.selected_or_first_available_variant -%}
                    <tr class="quick-order-list__row" data-qol-row>
                      <td class="quick-order-list__td quick-order-list__td--media">
                        <a href="{{ product.url }}" class="quick-order-list__media-link" tabindex="-1">
                          {%- if product.featured_image -%}
                            {%- assign qol_img_alt = product.featured_image.alt | default: product.title -%}
                            {{
                              product.featured_image
                              | image_url: width: 160
                              | image_tag:
                                loading: 'lazy',
                                class: 'quick-order-list__img',
                                widths: '80,120,160',
                                sizes: '72px',
                                alt: qol_img_alt
                            }}
                          {%- else -%}
                            <span class="quick-order-list__img-placeholder"></span>
                          {%- endif -%}
                        </a>
                      </td>
                      <td class="quick-order-list__td">
                        <a href="{{ product.url }}" class="quick-order-list__product-title">{{ product.title | escape }}</a>
                      </td>
                      <td class="quick-order-list__td">
                        {%- if product.has_only_default_variant -%}
                          <span class="quick-order-list__variant-static">{{ first_v.title | escape }}</span>
                          <input type="hidden" data-qol-variant-id value="{{ first_v.id }}">
                        {%- else -%}
                          <label class="visually-hidden" for="QolVariant-{{ section.id }}-{{ product.id }}">
                            {{- 'sections.quick_order_list.variant' | t }} — {{ product.title | escape -}}
                          </label>
                          <select
                            id="QolVariant-{{ section.id }}-{{ product.id }}"
                            class="quick-order-list__select"
                            data-qol-variant-select
                          >
                            {%- for variant in product.variants limit: 100 -%}
                              <option
                                value="{{ variant.id }}"
                                data-price-cents="{{ variant.price }}"
                                {% unless variant.available %}disabled{% endunless %}
                              >
                                {{ variant.title | escape }} — {{ variant.price | money }}
                              </option>
                            {%- endfor -%}
                          </select>
                        {%- endif -%}
                      </td>
                      <td class="quick-order-list__td quick-order-list__td--price" data-qol-price-cell>
                        <span class="price">{{ first_v.price | money }}</span>
                      </td>
                      <td class="quick-order-list__td">
                        <label class="visually-hidden" for="QolQty-{{ section.id }}-{{ product.id }}">
                          {{- 'products.product.quantity' | t }} — {{ product.title | escape -}}
                        </label>
                        <input
                          id="QolQty-{{ section.id }}-{{ product.id }}"
                          class="quick-order-list__qty"
                          type="number"
                          min="0"
                          value="0"
                          step="1"
                          data-qol-qty
                        >
                      </td>
                    </tr>
                  {%- endfor -%}
                </tbody>
              </table>
            </div>

            <p class="quick-order-list__status" data-qol-status role="status" hidden></p>

            <div class="quick-order-list__actions">
              <button type="submit" class="btn btn--solid">{{ 'sections.quick_order_list.add_all' | t }}</button>
            </div>
          </form>

          {%- if paginate.pages > 1 -%}
            <nav class="quick-order-list__pagination" aria-label="{{ 'collections.pagination' | t }}">
              {{- paginate | default_pagination -}}
            </nav>
          {%- endif -%}
        {%- endif -%}
      {%- endpaginate -%}
    {%- endif -%}
  </div>
</section>

<script src="{{ 'section-quick-order-list.js' | asset_url }}" defer></script>

{% stylesheet %}
  .quick-order-list__title {
    margin: 0 0 var(--spacing-md);
    font-size: var(--font-size-h3);
  }

  .quick-order-list__empty {
    margin: 0;
    opacity: 0.85;
  }

  .quick-order-list__table-wrap {
    overflow-x: auto;
    margin-bottom: var(--spacing-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
  }

  .quick-order-list__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9375rem;
  }

  .quick-order-list__th,
  .quick-order-list__td {
    padding: var(--spacing-sm) var(--spacing-md);
    text-align: start;
    vertical-align: middle;
    border-bottom: 1px solid var(--color-border);
  }

  .quick-order-list__th {
    font-weight: 600;
    background: rgb(var(--color-foreground-rgb, 26 26 26) / 0.04);
  }

  .quick-order-list__th--media {
    width: 5rem;
  }

  .quick-order-list__td--media {
    width: 5rem;
  }

  .quick-order-list__media-link {
    display: block;
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: var(--color-border);
  }

  .quick-order-list__img {
    width: 4.5rem;
    height: auto;
    display: block;
  }

  .quick-order-list__img-placeholder {
    display: block;
    width: 4.5rem;
    aspect-ratio: 1;
    background: var(--color-border);
  }

  .quick-order-list__product-title {
    font-weight: 600;
    color: inherit;
    text-decoration: none;
  }

  .quick-order-list__product-title:hover {
    text-decoration: underline;
  }

  .quick-order-list__select,
  .quick-order-list__qty {
    font: inherit;
    padding: 0.5rem 0.65rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-background);
    color: inherit;
    min-width: 0;
    max-width: 100%;
  }

  .quick-order-list__qty {
    width: 5rem;
  }

  .quick-order-list__status {
    margin: 0 0 var(--spacing-sm);
    font-size: 0.875rem;
  }

  .quick-order-list__status.is-error {
    color: var(--color-primary, #b00020);
  }

  .quick-order-list__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
  }

  .quick-order-list__pagination {
    margin-top: var(--spacing-md);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.quick_order_list.name",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "t:sections.quick_order_list.settings.title.label",
      "default": "Quick order"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.quick_order_list.settings.collection.label"
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "t:sections.quick_order_list.settings.products_limit.label",
      "min": 4,
      "max": 50,
      "step": 1,
      "default": 20
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.quick_order_list.settings.color_scheme.label",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "t:sections.quick_order_list.name"
    }
  ]
}
{% endschema %}
