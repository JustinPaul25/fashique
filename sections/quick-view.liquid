{%- comment -%}
  Minimal product UI for the Quick view dialog (Section Rendering API: ?view=quick-view&sections=main).
{%- endcomment -%}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign qv_form_id = 'QuickViewForm-' | append: section.id
-%}

<div class="quick-view" data-quick-view-root>
  <div class="quick-view__layout">
    <div class="quick-view__media">
      {%- if product.featured_media -%}
        <div class="quick-view__img-wrap" data-qv-media>
          {{
            product.featured_media
            | image_url: width: 800
            | image_tag:
              loading: 'lazy',
              class: 'quick-view__img',
              widths: '400,600,800',
              sizes: '(min-width: 600px) 45vw, 90vw',
              alt: product.featured_media.alt | default: product.title
          }}
        </div>
      {%- endif -%}
    </div>

    <div class="quick-view__panel">
      <h2 id="quick-view-title" class="quick-view__title">
        <a href="{{ product.url }}">{{ product.title | escape }}</a>
      </h2>

      <div class="quick-view__price" data-qv-price>
        {%- render 'price', product: product, variant: current_variant -%}
      </div>

      {%- form 'product', product, id: qv_form_id, class: 'quick-view__form', novalidate: 'novalidate' -%}
        <input type="hidden" name="id" value="{{ current_variant.id }}" data-qv-variant-id>

        {%- unless product.has_only_default_variant -%}
          <div class="quick-view__options" data-qv-options>
            {%- for option in product.options_with_values -%}
              <div class="quick-view__option">
                <label class="quick-view__label" for="QVOpt-{{ section.id }}-{{ forloop.index0 }}">
                  {{- option.name | escape -}}
                </label>
                <select
                  id="QVOpt-{{ section.id }}-{{ forloop.index0 }}"
                  class="quick-view__select"
                  data-qv-option="{{ forloop.index0 }}"
                  name="options[{{ option.name | escape }}]"
                >
                  {%- for option_value in option.values -%}
                    {%- assign ov = option_value.name | default: option_value -%}
                    <option
                      value="{{ ov | escape }}"
                      {% if ov == current_variant.options[forloop.parentloop.index0] %}selected{% endif %}
                    >
                      {{ ov | escape }}
                    </option>
                  {%- endfor -%}
                </select>
              </div>
            {%- endfor -%}
          </div>
        {%- endunless -%}

        <div class="quick-view__qty-row">
          <label class="quick-view__label" for="QVQty-{{ section.id }}">{{ 'products.product.quantity' | t }}</label>
          <input
            id="QVQty-{{ section.id }}"
            type="number"
            name="quantity"
            class="quick-view__qty"
            value="1"
            min="1"
            data-qv-qty
          >
        </div>

        <button type="submit" name="add" class="btn btn--solid quick-view__submit" data-qv-submit {% unless current_variant.available %}disabled{% endunless %}>
          {%- if current_variant.available -%}
            {{- 'products.product.add_to_cart' | t -}}
          {%- else -%}
            {{- 'products.product.sold_out' | t -}}
          {%- endif -%}
        </button>
      {%- endform -%}
    </div>
  </div>

  <script type="application/json" data-qv-variants>
    [
      {%- for variant in product.variants -%}
        {
          "id": {{ variant.id | json }},
          "options": {{ variant.options | json }},
          "price": {{ variant.price | json }},
          "compare_at_price": {{ variant.compare_at_price | json }},
          "available": {{ variant.available | json }},
          "featured_media_id": {% if variant.featured_media %}{{ variant.featured_media.id | json }}{% else %}null{% endif %}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  </script>

  <script type="application/json" data-qv-media-by-id>
    {
      {%- for media in product.media -%}
        {{ media.id | json }}: {{ media | image_url: width: 800 | json }}{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    }
  </script>
</div>

{% stylesheet %}
  .quick-view__layout {
    display: grid;
    gap: var(--spacing-md);
    max-width: 52rem;
  }

  @media screen and (min-width: 640px) {
    .quick-view__layout {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      align-items: start;
    }
  }

  .quick-view__img-wrap {
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-border);
  }

  .quick-view__img {
    width: 100%;
    height: auto;
    display: block;
  }

  .quick-view__title {
    font-size: 1.25rem;
    margin: 0 0 var(--spacing-sm);
  }

  .quick-view__title a {
    color: inherit;
    text-decoration: none;
  }

  .quick-view__title a:hover {
    text-decoration: underline;
  }

  .quick-view__price {
    margin-bottom: var(--spacing-md);
  }

  .quick-view__option {
    margin-bottom: var(--spacing-sm);
  }

  .quick-view__label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .quick-view__select,
  .quick-view__qty {
    width: 100%;
    max-width: 16rem;
    min-height: 2.75rem;
    padding: 0.5rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    background: var(--color-background);
    color: inherit;
    font: inherit;
  }

  .quick-view__qty-row {
    margin: var(--spacing-md) 0;
  }

  .quick-view__submit {
    width: 100%;
    max-width: 16rem;
    min-height: 3rem;
    margin-top: var(--spacing-sm);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.quick_view.name",
  "settings": []
}
{% endschema %}
