{%- comment -%}
  Rich Text  (Phase 5.1)
  ───────────────────────
  • Centered or split (text + side image) layout.
  • Eyebrow tag, heading, body richtext, and optional CTA button.
  • Alignment is configurable independently of layout.
{%- endcomment -%}

{%- render 'section-spacing', section: section -%}
<section
  class="rich-text section-padding rich-text--{{ section.settings.layout }} color-scheme color-{{ section.settings.color_scheme }}"
  data-section-id="{{ section.id }}"
>
  <div class="page-width">
    <div class="rich-text__content rich-text__content--{{ section.settings.alignment }}">

      {%- if section.settings.eyebrow != blank -%}
        <p class="rich-text__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="rich-text__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="rich-text__body rte">{{ section.settings.text }}</div>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a
          href="{{ section.settings.button_url | default: '#' }}"
          class="rich-text__cta btn btn--solid"
        >
          {{- section.settings.button_label | escape -}}
        </a>
      {%- endif -%}

    </div>
  </div>
</section>

{% stylesheet %}
  /* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
     RICH TEXT
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

  .rich-text {
    background-color: var(--color-background);
    color: var(--color-foreground);
    padding-block: var(--section-padding-block);
  }

  .rich-text__content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    max-width: 48rem;
  }

  .rich-text__content--center { align-items: center; text-align: center; margin-inline: auto; }
  .rich-text__content--right  { align-items: flex-end; text-align: end; margin-inline-start: auto; }

  .rich-text__eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin: 0;
  }

  .rich-text__heading {
    font-size: var(--font-size-h2);
    font-family: var(--font-heading-family);
    font-weight: var(--font-heading-weight);
    letter-spacing: var(--font-heading-letter-spacing, -0.02em);
    line-height: var(--font-heading-line-height, 1.1);
    margin: 0;
  }

  .rich-text__body {
    font-size: clamp(1rem, 1.5vw, 1.0625rem);
    line-height: 1.7;
    color: color-mix(in srgb, var(--color-foreground) 80%, transparent);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.rich_text.name",
  "tag": "section",
  "class": "section-rich-text",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.rich_text.settings.eyebrow.label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.rich_text.settings.heading.label",
      "default": "Talk about your brand"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "t:sections.rich_text.settings.text.label",
      "default": "<p>Share information about your brand with your customers. Describe a product, make announcements, or welcome customers to your store.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.rich_text.settings.button_label.label"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "t:sections.rich_text.settings.button_url.label"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "t:sections.rich_text.settings.alignment.label",
      "options": [
        { "value": "left",   "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" },
        { "value": "right",  "label": "t:options.alignment.right" }
      ],
      "default": "center"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:labels.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_spacing",
      "label": "t:labels.section_spacing",
      "info": "t:info.section_spacing",
      "options": [
        { "value": "default", "label": "t:options.section_spacing.default" },
        { "value": "none",    "label": "t:options.section_spacing.none"    },
        { "value": "xs",      "label": "t:options.section_spacing.xs"      },
        { "value": "sm",      "label": "t:options.section_spacing.sm"      },
        { "value": "md",      "label": "t:options.section_spacing.md"      },
        { "value": "lg",      "label": "t:options.section_spacing.lg"      },
        { "value": "xl",      "label": "t:options.section_spacing.xl"      }
      ],
      "default": "default"
    }
  ],
  "presets": [
    {
      "name": "t:sections.rich_text.name",
      "settings": {
        "eyebrow": "Our story",
        "heading": "Crafted with intention",
        "text": "<p>We believe fashion should be both beautiful and conscious. Every piece in our collection is designed to last — in quality and in style.</p>",
        "alignment": "center"
      }
    }
  ]
}
{% endschema %}
