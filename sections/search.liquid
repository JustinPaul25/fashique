{%- comment -%}
  Search template (Phase 5.5): form, predictive suggestions, results with product cards, no-results CTA.
{%- endcomment -%}

{%- render 'article-card-styles' -%}

{%- liquid
  assign per_page = section.settings.results_per_page | default: 24 | plus: 0
  assign show_vendor = section.settings.show_vendor
  assign enable_predictive = section.settings.enable_predictive
-%}

{%- render 'section-spacing', section: section -%}

<div
  class="search-page section-padding color-scheme color-{{ section.settings.color_scheme }}"
  {% if enable_predictive %}
    data-search-page
    data-enable-predictive="true"
    data-predictive-url="{{ routes.predictive_search_url | escape }}"
    data-section-id="predictive-search"
    data-live-msg="{{ 'search.predictive_live' | t | escape }}"
  {% endif %}
>
  <div class="search-page__inner page-width">
    <h1 class="search-page__title">{{ 'search.title' | t }}</h1>

    <form
      action="{{ routes.search_url }}"
      method="get"
      role="search"
      class="search-page__form"
    >
      <label class="visually-hidden" for="SearchInput-{{ section.id }}">{{ 'search.placeholder' | t }}</label>
      <div class="search-page__field{% if enable_predictive %} search-page__field--predictive{% endif %}">
        <input
          type="search"
          name="q"
          id="SearchInput-{{ section.id }}"
          class="search-page__input"
          value="{{ search.terms | escape }}"
          placeholder="{{ 'search.placeholder' | t }}"
          autocomplete="off"
          {% if enable_predictive %}
            data-search-input
            aria-autocomplete="list"
            aria-expanded="false"
            aria-controls="PredictiveWrap-{{ section.id }}"
          {% endif %}
        >
        <button type="submit" class="btn btn--solid btn--md search-page__submit">
          {{- 'search.submit' | t -}}
        </button>
      </div>
      {%- if enable_predictive -%}
        <span id="SearchLive-{{ section.id }}" class="visually-hidden" role="status" aria-live="polite" data-search-live></span>
        <div
          id="PredictiveWrap-{{ section.id }}"
          class="search-page__predictive-wrap"
          data-predictive-wrap
          hidden
        >
          <div class="search-page__predictive color-scheme color-{{ section.settings.color_scheme }}" data-predictive-output></div>
        </div>
      {%- endif -%}
    </form>

    {%- if search.performed -%}
      {%- if search.results_count == 0 -%}
        <div class="search-page__empty">
          <p class="search-page__empty-title">{{ 'search.no_results_html' | t: terms: search.terms }}</p>
          <p class="search-page__empty-hint">{{ 'search.try_these' | t }}</p>
          <ul class="search-page__empty-links list-unstyled">
            <li>
              <a href="{{ routes.all_products_collection_url }}" class="btn btn--outline btn--md">{{ 'search.bttn_all_products' | t }}</a>
            </li>
            <li>
              <a href="{{ routes.collections_url }}" class="btn btn--outline btn--md">{{ 'search.bttn_collections' | t }}</a>
            </li>
            <li>
              <a href="{{ routes.root_url }}" class="btn btn--outline btn--md">{{ 'search.bttn_home' | t }}</a>
            </li>
          </ul>
        </div>
      {%- else -%}
        <p class="search-page__summary">{{ 'search.results_for_html' | t: terms: search.terms, count: search.results_count }}</p>

        {% paginate search.results by per_page %}
          <div class="search-page__grid">
            {%- for item in search.results -%}
              {%- case item.object_type -%}
                {%- when 'product' -%}
                  <div class="search-page__cell">
                    {%
                      render 'product-card',
                      product: item,
                      show_vendor: show_vendor,
                      show_quick_view: section.settings.show_quick_view and settings.enable_quick_view,
                      sizes: '(min-width: 1200px) 25vw, (min-width: 750px) 33vw, 50vw'
                    %}
                  </div>
                {%- when 'article' -%}
                  <div class="search-page__cell search-page__cell--wide">
                    {% render 'article-card', article: item %}
                  </div>
                {%- when 'page' -%}
                  <div class="search-page__cell search-page__cell--text">
                    <a href="{{ item.url }}" class="search-page__page-hit">
                      <span class="search-page__page-kicker">{{ 'search.result_page' | t }}</span>
                      <span class="search-page__page-title">{{ item.title | escape }}</span>
                    </a>
                  </div>
                {%- else -%}
                  <div class="search-page__cell search-page__cell--text">
                    <a href="{{ item.url }}" class="search-page__page-hit">
                      <span class="search-page__page-title">{{ item.title | escape }}</span>
                    </a>
                  </div>
              {%- endcase -%}
            {%- endfor -%}
          </div>

          <nav class="search-page__pagination" aria-label="{{ 'search.pagination_label' | t }}">
            {{- paginate | default_pagination -}}
          </nav>
        {% endpaginate %}
      {%- endif -%}
    {%- endif -%}
  </div>
</div>

<script src="{{ 'component-product-card-swatches.js' | asset_url }}" defer></script>
{%- if enable_predictive -%}
  <script src="{{ 'section-search.js' | asset_url }}" defer></script>
{%- endif -%}

{% stylesheet %}
  .search-page__inner {
    max-width: var(--page-width);
    margin-inline: auto;
  }

  .search-page__title {
    font-size: var(--font-size-h2);
    font-family: var(--font-heading-family);
    margin: 0 0 var(--spacing-lg);
  }

  .search-page__form {
    position: relative;
    margin-block-end: var(--spacing-xl);
  }

  .search-page__field {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    align-items: stretch;
  }

  .search-page__input {
    flex: 1 1 16rem;
    min-height: 3rem;
    padding: 0 1rem;
    font: inherit;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-background);
    color: inherit;
  }

  .search-page__predictive-wrap {
    position: absolute;
    z-index: 30;
    left: 0;
    right: 0;
    top: 100%;
    margin-top: 0.35rem;
  }

  .search-page__predictive {
    max-height: min(70vh, 28rem);
    overflow: auto;
    padding: var(--spacing-sm);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    box-shadow: 0 12px 40px rgb(0 0 0 / 0.12);
    background: var(--color-background);
  }

  .predictive-search__panel {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .predictive-search__heading {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.75;
  }

  .predictive-search__list {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .predictive-search__row {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: 0.35rem 0.25rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: inherit;
    min-height: 3.25rem;
  }

  .predictive-search__row:hover,
  .predictive-search__row:focus-visible {
    background: color-mix(in srgb, var(--color-foreground) 6%, var(--color-background));
    outline: none;
  }

  .predictive-search__row--text {
    min-height: auto;
    padding: 0.5rem 0.35rem;
  }

  .predictive-search__thumb {
    width: 3rem;
    height: 3rem;
    flex-shrink: 0;
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .predictive-search__thumb--empty svg {
    width: 65%;
    height: auto;
    opacity: 0.45;
  }

  .predictive-search__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .predictive-search__row-text {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .predictive-search__title {
    font-weight: 600;
    font-size: 0.9375rem;
    line-height: 1.25;
  }

  .predictive-search__meta .price {
    font-size: 0.875rem;
  }

  .predictive-search__empty {
    margin: 0;
    padding: var(--spacing-sm);
    font-size: 0.9375rem;
    opacity: 0.85;
  }

  .search-page__summary {
    margin: 0 0 var(--spacing-md);
    font-size: 1rem;
  }

  .search-page__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr));
    gap: var(--spacing-md);
    margin-block-end: var(--spacing-xl);
  }

  .search-page__cell--wide {
    grid-column: span 1;
  }

  @media screen and (min-width: 750px) {
    .search-page__cell--wide {
      grid-column: span 2;
    }
  }

  .search-page__cell--text {
    grid-column: 1 / -1;
  }

  .search-page__page-hit {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: var(--spacing-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: inherit;
  }

  .search-page__page-hit:hover {
    border-color: color-mix(in srgb, var(--color-foreground) 20%, var(--color-border));
  }

  .search-page__page-kicker {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.7;
  }

  .search-page__page-title {
    font-size: var(--font-size-h5);
    font-family: var(--font-heading-family);
  }

  .search-page__empty {
    text-align: center;
    padding-block: var(--spacing-xl);
    max-width: 36rem;
    margin-inline: auto;
  }

  .search-page__empty-title {
    font-size: var(--font-size-h4);
    margin: 0 0 var(--spacing-sm);
  }

  .search-page__empty-hint {
    margin: 0 0 var(--spacing-md);
    opacity: 0.85;
  }

  .search-page__empty-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    justify-content: center;
  }

  .search-page__pagination {
    margin-block-start: var(--spacing-lg);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.search.name",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_predictive",
      "label": "t:sections.search.settings.enable_predictive.label",
      "info": "t:sections.search.settings.enable_predictive.info",
      "default": true
    },
    {
      "type": "range",
      "id": "results_per_page",
      "min": 8,
      "max": 48,
      "step": 4,
      "label": "t:sections.search.settings.results_per_page.label",
      "default": 24
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:sections.search.settings.show_vendor.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_quick_view",
      "label": "t:sections.search.settings.show_quick_view.label",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:labels.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_spacing",
      "label": "t:labels.section_spacing",
      "info": "t:info.section_spacing",
      "options": [
        { "value": "default", "label": "t:options.section_spacing.default" },
        { "value": "none",    "label": "t:options.section_spacing.none"    },
        { "value": "xs",      "label": "t:options.section_spacing.xs"      },
        { "value": "sm",      "label": "t:options.section_spacing.sm"      },
        { "value": "md",      "label": "t:options.section_spacing.md"      },
        { "value": "lg",      "label": "t:options.section_spacing.lg"      },
        { "value": "xl",      "label": "t:options.section_spacing.xl"      }
      ],
      "default": "md"
    }
  ]
}
{% endschema %}
