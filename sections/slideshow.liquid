{%- comment -%}
  Slideshow / Hero  (Phase 5.1)
  ──────────────────────────────
  • Splide-powered full-bleed carousel when more than one slide is present.
  • Single slide: no Splide overhead — static markup only.
  • Per-slide: background image, heading, subheading, CTA, text position, overlay opacity.
  • Autoplay and transitions respect prefers-reduced-motion via splide-init.js.
{%- endcomment -%}

{%- assign slide_blocks = section.blocks | where: 'type', 'slide' -%}
{%- assign slide_count  = slide_blocks.size -%}
{%- render 'section-spacing', section: section -%}

{%- if slide_count == 0 -%}
  {%- if request.design_mode -%}
    <div class="slideshow slideshow--placeholder color-scheme color-{{ section.settings.color_scheme }}">
      <p class="slideshow__empty-hint">Add a <strong>Slide</strong> block in the editor to get started.</p>
    </div>
  {%- endif -%}

{%- elsif slide_count == 1 -%}

  {%- assign block = slide_blocks[0] -%}
  {%- assign overlay_alpha = block.settings.overlay_opacity | divided_by: 100.0 -%}
  <section
    class="slideshow slideshow--{{ section.settings.slide_height }} color-scheme color-{{ section.settings.color_scheme }}"
    data-section-id="{{ section.id }}"
  >
    <div class="slideshow__slide" {{ block.shopify_attributes }}>
      <div class="slideshow__bg">
        {%- render 'image',
          image: block.settings.image,
          widths: '750,1100,1500,1780,2000',
          sizes: '100vw',
          alt: block.settings.image.alt | default: block.settings.heading,
          class: 'slideshow__bg-img',
          loading: 'eager',
          placeholder_type: 'lifestyle-1'
        -%}
      </div>
      <div
        class="slideshow__overlay"
        style="--slide-overlay-alpha: {{ overlay_alpha }}"
        aria-hidden="true"
      ></div>
      <div class="slideshow__content slideshow__content--{{ block.settings.text_position }}">
        <div class="slideshow__inner">
          {%- if block.settings.heading != blank -%}
            <h2 class="slideshow__heading">{{ block.settings.heading | escape }}</h2>
          {%- endif -%}
          {%- if block.settings.subheading != blank -%}
            <p class="slideshow__subheading">{{ block.settings.subheading | escape }}</p>
          {%- endif -%}
          {%- if block.settings.cta_label != blank and block.settings.cta_url != blank -%}
            <a href="{{ block.settings.cta_url }}" class="slideshow__cta btn btn--solid">
              {{- block.settings.cta_label | escape -}}
            </a>
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>

{%- else -%}

  <section
    class="slideshow slideshow--{{ section.settings.slide_height }} color-scheme color-{{ section.settings.color_scheme }}"
    data-section-id="{{ section.id }}"
  >
    <div
      class="splide slideshow__splide"
      data-splide-config='{"type":"loop","autoplay":{{ section.settings.autoplay | json }},"interval":{{ section.settings.autoplay_speed | times: 1000 }},"arrows":{{ section.settings.show_arrows | json }},"pagination":{{ section.settings.show_dots | json }},"speed":600,"rewind":false}'
      aria-label="{{ 'sections.slideshow.scroll_label' | t }}"
    >
      <div class="splide__track">
        <ul class="splide__list">
          {%- for block in slide_blocks -%}
            {%- assign overlay_alpha = block.settings.overlay_opacity | divided_by: 100.0 -%}
            <li
              class="splide__slide slideshow__slide"
              {{ block.shopify_attributes }}
            >
              <div class="slideshow__bg">
                {%- render 'image',
                  image: block.settings.image,
                  widths: '750,1100,1500,1780,2000',
                  sizes: '100vw',
                  alt: block.settings.image.alt | default: block.settings.heading,
                  class: 'slideshow__bg-img',
                  loading: forloop.first | default: 'lazy',
                  placeholder_type: 'lifestyle-1'
                -%}
              </div>
              <div
                class="slideshow__overlay"
                style="--slide-overlay-alpha: {{ overlay_alpha }}"
                aria-hidden="true"
              ></div>
              <div class="slideshow__content slideshow__content--{{ block.settings.text_position }}">
                <div class="slideshow__inner">
                  {%- if block.settings.heading != blank -%}
                    <h2 class="slideshow__heading">{{ block.settings.heading | escape }}</h2>
                  {%- endif -%}
                  {%- if block.settings.subheading != blank -%}
                    <p class="slideshow__subheading">{{ block.settings.subheading | escape }}</p>
                  {%- endif -%}
                  {%- if block.settings.cta_label != blank and block.settings.cta_url != blank -%}
                    <a href="{{ block.settings.cta_url }}" class="slideshow__cta btn btn--solid">
                      {{- block.settings.cta_label | escape -}}
                    </a>
                  {%- endif -%}
                </div>
              </div>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    </div>
  </section>

  <link
    rel="stylesheet"
    href="{{ 'splide.min.css' | asset_url }}"
    media="print"
    onload="this.media='all'"
  >
  <noscript><link rel="stylesheet" href="{{ 'splide.min.css' | asset_url }}"></noscript>
  <script src="{{ 'splide.min.js' | asset_url }}" defer></script>
  <script src="{{ 'splide-init.js' | asset_url }}" defer></script>

{%- endif -%}

{% stylesheet %}
  /* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
     SLIDESHOW
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

  .slideshow {
    position: relative;
    overflow: hidden;
    background-color: var(--color-background);
  }

  /* Height variants */
  .slideshow--small  .slideshow__slide { min-height: clamp(18rem, 40svh, 30rem); }
  .slideshow--medium .slideshow__slide { min-height: clamp(25rem, 60svh, 48rem); }
  .slideshow--large  .slideshow__slide { min-height: clamp(30rem, 80svh, 64rem); }
  .slideshow--full   .slideshow__slide { min-height: 100svh; }

  /* Slide layout */
  .slideshow__slide {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
    overflow: hidden;
  }

  /* Background image */
  .slideshow__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .slideshow__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Overlay — uses CSS custom property set inline per slide */
  .slideshow__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background-color: rgba(0, 0, 0, var(--slide-overlay-alpha, 0.35));
    pointer-events: none;
  }

  /* Content */
  .slideshow__content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: var(--page-margin, 1.25rem);
    padding-block: var(--spacing-2xl, 5rem);
    color: #fff;
  }

  .slideshow__content--left   { text-align: start; }
  .slideshow__content--center { text-align: center; }
  .slideshow__content--right  { text-align: end; }

  .slideshow__content--bottom_left,
  .slideshow__content--bottom_center,
  .slideshow__content--bottom_right {
    align-self: stretch;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-block-start: var(--spacing-2xl, 5rem);
    padding-block-end: var(--spacing-2xl, 5rem);
  }

  .slideshow__content--bottom_left   { text-align: start; }
  .slideshow__content--bottom_center { text-align: center; }
  .slideshow__content--bottom_right  { text-align: end; }

  .slideshow__inner {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md, 1.5rem);
  }

  .slideshow__content--center .slideshow__inner,
  .slideshow__content--bottom_center .slideshow__inner {
    align-items: center;
  }

  .slideshow__content--right .slideshow__inner,
  .slideshow__content--bottom_right .slideshow__inner {
    align-items: flex-end;
  }

  .slideshow__heading {
    font-size: var(--font-size-h1);
    font-family: var(--font-heading-family);
    font-weight: var(--font-heading-weight);
    letter-spacing: var(--font-heading-letter-spacing, -0.02em);
    line-height: var(--font-heading-line-height, 1.1);
    color: inherit;
    margin: 0;
    max-width: 18ch;
  }

  .slideshow__subheading {
    font-size: clamp(1rem, 2vw, 1.25rem);
    line-height: 1.55;
    margin: 0;
    opacity: 0.9;
    max-width: 44ch;
  }

  /*
   * .slideshow__cta extends .btn.btn--solid (classes are set in the Liquid
   * template). Only layout-specific overrides belong here — all colour and
   * shape rules are inherited from assets/buttons.css via the shared tokens.
   */
  .slideshow__cta {
    align-self: flex-start;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .slideshow__content--center .slideshow__cta,
  .slideshow__content--bottom_center .slideshow__cta {
    align-self: center;
  }

  .slideshow__content--right .slideshow__cta,
  .slideshow__content--bottom_right .slideshow__cta {
    align-self: flex-end;
  }

  /* Splide overrides */
  .slideshow .splide__track,
  .slideshow .splide__list {
    height: 100%;
  }

  .slideshow .splide__arrow {
    width: 3rem;
    height: 3rem;
    background-color: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 50%;
    transition: background-color var(--transition-base, 0.25s ease);
  }

  .slideshow .splide__arrow:hover {
    background-color: rgba(255, 255, 255, 0.35);
  }

  .slideshow .splide__arrow:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 3px;
  }

  .slideshow .splide__arrow svg {
    fill: none;
    stroke: #fff;
    stroke-width: 2;
    width: 1.25rem;
    height: 1.25rem;
  }

  .slideshow .splide__pagination {
    bottom: 1.25rem;
    gap: 0.375rem;
  }

  .slideshow .splide__pagination__page {
    width: 0.5rem;
    height: 0.5rem;
    background-color: rgba(255, 255, 255, 0.5);
    border: none;
    border-radius: 50%;
    transition:
      background-color var(--transition-base, 0.25s ease),
      width var(--transition-base, 0.25s ease);
  }

  .slideshow .splide__pagination__page.is-active {
    background-color: #fff;
    width: 1.5rem;
    border-radius: 0.25rem;
  }

  /* Placeholder (editor only) */
  .slideshow--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 30rem;
    border: 2px dashed var(--color-border);
  }

  .slideshow__empty-hint {
    opacity: 0.5;
    font-size: 0.875rem;
    margin: 0;
  }

  .slideshow__bg .image-placeholder {
    position: absolute;
    inset: 0;
  }

  .slideshow__bg .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (prefers-reduced-motion: reduce) {
    .slideshow .splide__slide { transition: none !important; }
    .slideshow__cta.btn       { transition: none; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.slideshow.name",
  "tag": "section",
  "class": "section-slideshow",
  "settings": [
    {
      "type": "select",
      "id": "slide_height",
      "label": "t:sections.slideshow.settings.slide_height.label",
      "options": [
        { "value": "small",  "label": "t:options.size.small" },
        { "value": "medium", "label": "t:options.size.medium" },
        { "value": "large",  "label": "t:options.size.large" },
        { "value": "full",   "label": "t:options.size.full" }
      ],
      "default": "large"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "t:sections.slideshow.settings.show_arrows.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "t:sections.slideshow.settings.show_dots.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "t:sections.slideshow.settings.autoplay.label",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "t:sections.slideshow.settings.autoplay_speed.label",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 5
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:labels.color_scheme",
      "default": "scheme-2"
    },
    {
      "type": "select",
      "id": "section_spacing",
      "label": "t:labels.section_spacing",
      "info": "t:info.section_spacing",
      "options": [
        { "value": "default", "label": "t:options.section_spacing.default" },
        { "value": "none",    "label": "t:options.section_spacing.none"    },
        { "value": "xs",      "label": "t:options.section_spacing.xs"      },
        { "value": "sm",      "label": "t:options.section_spacing.sm"      },
        { "value": "md",      "label": "t:options.section_spacing.md"      },
        { "value": "lg",      "label": "t:options.section_spacing.lg"      },
        { "value": "xl",      "label": "t:options.section_spacing.xl"      }
      ],
      "default": "default"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "t:blocks.slide.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:blocks.slide.settings.image.label"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:blocks.slide.settings.heading.label",
          "default": "Bold Heading Here"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "t:blocks.slide.settings.subheading.label",
          "default": "A compelling line about your collection or campaign."
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "t:blocks.slide.settings.cta_label.label",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "t:blocks.slide.settings.cta_url.label"
        },
        {
          "type": "select",
          "id": "text_position",
          "label": "t:blocks.slide.settings.text_position.label",
          "options": [
            { "value": "left",          "label": "t:options.text_position.left" },
            { "value": "center",        "label": "t:options.text_position.center" },
            { "value": "right",         "label": "t:options.text_position.right" },
            { "value": "bottom_left",   "label": "t:options.text_position.bottom_left" },
            { "value": "bottom_center", "label": "t:options.text_position.bottom_center" },
            { "value": "bottom_right",  "label": "t:options.text_position.bottom_right" }
          ],
          "default": "center"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "t:blocks.slide.settings.overlay_opacity.label",
          "min": 0,
          "max": 80,
          "step": 5,
          "default": 35
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.slideshow.name",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "heading": "New Collection",
            "subheading": "Discover the latest arrivals — refined elegance for every occasion.",
            "cta_label": "Shop now",
            "text_position": "center",
            "overlay_opacity": 35
          }
        },
        {
          "type": "slide",
          "settings": {
            "heading": "Timeless Style",
            "subheading": "Curated essentials that never go out of fashion.",
            "cta_label": "Explore",
            "text_position": "bottom_left",
            "overlay_opacity": 40
          }
        }
      ]
    }
  ]
}
{% endschema %}
