{%- comment -%}
  UGC Photo Grid  (Phase 5.1 / Phase 6.5)
  ─────────────────────────────────────────
  • Instagram-style photo grid (3–4 columns).
  • Each cell: manually uploaded image, optional product link, optional caption.
  • Lightbox on click via native <dialog> — no third-party library.
  • Schema blocks: image picker + product picker + caption.
{%- endcomment -%}

{%- assign photo_blocks = section.blocks | where: 'type', 'photo' -%}

{%- render 'section-spacing', section: section -%}
<section
  class="ugc-grid section-padding color-scheme color-{{ section.settings.color_scheme }}"
  data-section-id="{{ section.id }}"
>
  <div class="page-width">

    {%- if section.settings.title != blank -%}
      <h2 class="ugc-grid__title section-heading">{{ section.settings.title | escape }}</h2>
    {%- endif -%}

    {%- if photo_blocks.size > 0 -%}
      <ul
        class="ugc-grid__grid ugc-grid__grid--{{ section.settings.columns_desktop }} list-unstyled"
        role="list"
      >
        {%- for block in photo_blocks -%}
          {%- assign ugc_placeholder_num = forloop.index | modulo: 2 | plus: 1 -%}
          {%- assign ugc_placeholder = 'lifestyle-' | append: ugc_placeholder_num -%}
          <li
            class="ugc-grid__item{% if block.settings.image == blank %} ugc-grid__item--placeholder{% endif %}"
            {{ block.shopify_attributes }}
          >
            <button
              type="button"
              class="ugc-grid__trigger"
              aria-label="{{ 'accessibility.view_product' | t: title: block.settings.caption | default: block.settings.image.alt | escape }}"
              data-ugc-open="{{ forloop.index0 }}"
            >
              {%- render 'image',
                image: block.settings.image,
                widths: '300,480,640',
                sizes: '(min-width: 1024px) 25vw, (min-width: 640px) 33vw, 50vw',
                alt: block.settings.image.alt | default: block.settings.caption,
                class: 'ugc-grid__img',
                loading: 'lazy',
                placeholder_type: ugc_placeholder
              -%}
              {%- if block.settings.image == blank -%}
                <span class="visually-hidden">{{ 'sections.ugc_grid.photo_placeholder' | t }}</span>
              {%- endif -%}
                {%- if block.settings.caption != blank or block.settings.product != blank -%}
                  <div class="ugc-grid__item-overlay" aria-hidden="true">
                    {%- if block.settings.caption != blank -%}
                      <p class="ugc-grid__item-caption">{{ block.settings.caption | escape }}</p>
                    {%- endif -%}
                    {%- if block.settings.product != blank -%}
                      <span class="ugc-grid__item-tag">{{ 'accessibility.view_product' | t: title: '' }}</span>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              </button>

              {%- comment -%} Lightbox dialog {%- endcomment -%}
              <dialog
                class="ugc-lightbox"
                id="ugc-lightbox-{{ section.id }}-{{ forloop.index0 }}"
                aria-modal="true"
                aria-label="{{ block.settings.caption | default: block.settings.image.alt | escape }}"
              >
                <button
                  type="button"
                  class="ugc-lightbox__close"
                  aria-label="{{ 'accessibility.close' | t }}"
                  data-ugc-close
                >
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24" aria-hidden="true">
                    <path d="M18 6 6 18M6 6l12 12"/>
                  </svg>
                </button>

                <div class="ugc-lightbox__content">
                  {%- render 'image',
                    image: block.settings.image,
                    widths: '600,900,1200',
                    sizes: '90vw',
                    alt: block.settings.image.alt | default: block.settings.caption,
                    class: 'ugc-lightbox__img',
                    loading: 'lazy',
                    placeholder_type: ugc_placeholder
                  -%}
                  {%- if block.settings.caption != blank or block.settings.product != blank -%}
                    <div class="ugc-lightbox__meta">
                      {%- if block.settings.caption != blank -%}
                        <p class="ugc-lightbox__caption">{{ block.settings.caption | escape }}</p>
                      {%- endif -%}
                      {%- if block.settings.product != blank -%}
                        {%- assign linked_product = all_products[block.settings.product] -%}
                        {%- if linked_product != blank -%}
                          <a href="{{ linked_product.url }}" class="ugc-lightbox__product-link btn btn--solid btn--sm">
                            {{- 'accessibility.view_product' | t: title: linked_product.title | escape -}}
                          </a>
                        {%- endif -%}
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                </div>
              </dialog>
            </li>
        {%- endfor -%}
      </ul>

      <script>
        (function () {
          'use strict';

          const section = document.querySelector('[data-section-id="{{ section.id }}"]');
          if (!section) return;

          /* Open lightbox */
          section.querySelectorAll('[data-ugc-open]').forEach(function (btn) {
            btn.addEventListener('click', function () {
              const idx     = btn.dataset.ugcOpen;
              const dialog  = section.querySelector('#ugc-lightbox-{{ section.id }}-' + idx);
              if (dialog) {
                dialog.showModal();
                dialog.querySelector('.ugc-lightbox__close').focus();
              }
            });
          });

          /* Close on close button */
          section.querySelectorAll('[data-ugc-close]').forEach(function (btn) {
            btn.addEventListener('click', function () {
              btn.closest('dialog').close();
            });
          });

          /* Close on backdrop click */
          section.querySelectorAll('.ugc-lightbox').forEach(function (dialog) {
            dialog.addEventListener('click', function (e) {
              if (e.target === dialog) dialog.close();
            });
          });
        })();
      </script>

    {%- elsif request.design_mode -%}
      <p class="ugc-grid__empty-hint">Add photo blocks to populate your photo grid.</p>
    {%- endif -%}

  </div>
</section>

{% stylesheet %}
  /* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
     UGC PHOTO GRID
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

  .ugc-grid {
    background-color: var(--color-background);
    color: var(--color-foreground);
    padding-block: var(--section-padding-block);
  }

  .ugc-grid__title {
    font-size: var(--font-size-h2);
    font-family: var(--font-heading-family);
    font-weight: var(--font-heading-weight);
    letter-spacing: var(--font-heading-letter-spacing, -0.02em);
    line-height: var(--font-heading-line-height, 1.1);
    text-align: center;
    margin: 0 0 var(--spacing-xl);
  }

  /* ── Grid ────────────────────────────────────────────────────────── */
  .ugc-grid__grid {
    display: grid;
    gap: 0.25rem;
    padding: 0;
    margin: 0;
  }

  .ugc-grid__grid--3 { grid-template-columns: repeat(3, 1fr); }
  .ugc-grid__grid--4 { grid-template-columns: repeat(4, 1fr); }

  @media (max-width: 640px) {
    .ugc-grid__grid--3,
    .ugc-grid__grid--4 { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 380px) {
    .ugc-grid__grid--3,
    .ugc-grid__grid--4 { grid-template-columns: repeat(2, 1fr); }
  }

  /* ── Grid item ───────────────────────────────────────────────────── */
  .ugc-grid__item {
    position: relative;
  }

  .ugc-grid__trigger {
    display: block;
    width: 100%;
    padding: 0;
    background: none;
    border: none;
    cursor: pointer;
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }

  .ugc-grid__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .ugc-grid__trigger:hover .ugc-grid__img,
  .ugc-grid__trigger:focus-visible .ugc-grid__img {
    transform: scale(1.04);
  }

  .ugc-grid__trigger:focus-visible {
    outline: 3px solid var(--color-primary);
    outline-offset: -3px;
  }

  /* ── Hover overlay ───────────────────────────────────────────────── */
  .ugc-grid__item-overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.5);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    opacity: 0;
    transition: opacity var(--transition-base);
    padding: var(--spacing-sm);
    text-align: center;
    color: #fff;
  }

  @media (hover: hover) {
    .ugc-grid__trigger:hover .ugc-grid__item-overlay { opacity: 1; }
  }

  @media (hover: none) {
    .ugc-grid__item-overlay { display: none; }
  }

  .ugc-grid__item-caption {
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.3;
    margin: 0;
  }

  .ugc-grid__item-tag {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.8;
  }

  /* ── Lightbox dialog ─────────────────────────────────────────────── */
  .ugc-lightbox {
    position: fixed;
    inset: 0;
    margin: auto;
    max-width: min(90vw, 54rem);
    max-height: 90svh;
    border: none;
    border-radius: var(--radius-md);
    overflow: hidden;
    padding: 0;
    background: #000;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
  }

  .ugc-lightbox::backdrop {
    background-color: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(4px);
  }

  .ugc-lightbox__content {
    display: flex;
    flex-direction: column;
    max-height: 90svh;
    overflow-y: auto;
  }

  .ugc-lightbox__img {
    width: 100%;
    max-height: 70svh;
    object-fit: contain;
    display: block;
  }

  .ugc-lightbox__meta {
    padding: var(--spacing-md) var(--spacing-lg);
    background: #fff;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    align-items: flex-start;
  }

  .ugc-lightbox__caption {
    font-size: 0.9375rem;
    font-weight: 500;
    margin: 0;
    color: #1a1a1a;
  }

  .ugc-lightbox__close {
    position: absolute;
    top: 0.75rem;
    inset-inline-end: 0.75rem;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    background-color: rgba(0, 0, 0, 0.55);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    color: #fff;
    transition: background-color var(--transition-base);
  }

  .ugc-lightbox__close:hover        { background-color: rgba(0, 0, 0, 0.8); }
  .ugc-lightbox__close:focus-visible { outline: 2px solid #fff; outline-offset: 2px; }

  /* ── Placeholder ─────────────────────────────────────────────────── */
  .ugc-grid__empty-hint {
    text-align: center;
    opacity: 0.5;
    font-size: 0.875rem;
    padding-block: var(--spacing-xl);
  }

  @media (prefers-reduced-motion: reduce) {
    .ugc-grid__img                    { transition: none; }
    .ugc-grid__item-overlay           { transition: none; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.ugc_grid.name",
  "tag": "section",
  "class": "section-ugc-grid",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "t:sections.ugc_grid.settings.title.label",
      "default": "Styled by you"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "t:sections.ugc_grid.settings.columns_desktop.label",
      "options": [
        { "value": "3", "label": "t:options.columns.three" },
        { "value": "4", "label": "t:options.columns.four" }
      ],
      "default": "4"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:labels.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_spacing",
      "label": "t:labels.section_spacing",
      "info": "t:info.section_spacing",
      "options": [
        { "value": "default", "label": "t:options.section_spacing.default" },
        { "value": "none",    "label": "t:options.section_spacing.none"    },
        { "value": "xs",      "label": "t:options.section_spacing.xs"      },
        { "value": "sm",      "label": "t:options.section_spacing.sm"      },
        { "value": "md",      "label": "t:options.section_spacing.md"      },
        { "value": "lg",      "label": "t:options.section_spacing.lg"      },
        { "value": "xl",      "label": "t:options.section_spacing.xl"      }
      ],
      "default": "default"
    }
  ],
  "blocks": [
    {
      "type": "photo",
      "name": "t:blocks.photo.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:blocks.photo.settings.image.label"
        },
        {
          "type": "product",
          "id": "product",
          "label": "t:blocks.photo.settings.product.label"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "t:blocks.photo.settings.caption.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.ugc_grid.name",
      "blocks": [
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" }
      ]
    }
  ]
}
{% endschema %}
