{%- comment -%}
  Video  (Phase 5.1)
  ───────────────────
  • Supports Shopify-hosted video files and YouTube / Vimeo embed URLs.
  • Cover image shown until user clicks play — no autoplay without user intent.
  • Heading and description optional above the player.
  • Native <video> for Shopify-hosted; iframe embed for external URLs.
{%- endcomment -%}

{%- assign has_shopify_video = false -%}
{%- assign has_ext_url      = false -%}
{%- if section.settings.video != blank -%}
  {%- assign has_shopify_video = true -%}
{%- elsif section.settings.video_url != blank -%}
  {%- assign has_ext_url = true -%}
{%- endif -%}

{%- comment -%} Parse external URL to generate the embed URL {%- endcomment -%}
{%- assign embed_url = '' -%}
{%- assign yt_id = '' -%}
{%- if has_ext_url -%}
  {%- assign raw_url = section.settings.video_url | strip -%}
  {%- comment -%} YouTube: watch, youtu.be, /embed/, /shorts/, /live/ {%- endcomment -%}
  {%- if raw_url contains 'youtube.com' or raw_url contains 'youtu.be' -%}
    {%- if raw_url contains 'youtu.be/' -%}
      {%- assign yt_id = raw_url | split: 'youtu.be/' | last | split: '?' | first | split: '/' | first -%}
    {%- elsif raw_url contains 'youtube.com/watch' -%}
      {%- if raw_url contains 'v=' -%}
        {%- assign yt_id = raw_url | split: 'v=' | last | split: '&' | first | split: '#' | first -%}
      {%- endif -%}
    {%- elsif raw_url contains 'youtube.com/embed/' -%}
      {%- assign yt_id = raw_url | split: 'embed/' | last | split: '?' | first | split: '/' | first -%}
    {%- elsif raw_url contains 'youtube.com/shorts/' -%}
      {%- assign yt_id = raw_url | split: 'shorts/' | last | split: '?' | first | split: '/' | first -%}
    {%- elsif raw_url contains 'youtube.com/live/' -%}
      {%- assign yt_id = raw_url | split: 'live/' | last | split: '?' | first | split: '/' | first -%}
    {%- endif -%}
    {%- if yt_id != blank -%}
      {%- assign embed_url = 'https://www.youtube-nocookie.com/embed/'
        | append: yt_id
        | append: '?rel=0&enablejsapi=1&autoplay=1&playsinline=1'
      -%}
    {%- endif -%}
  {%- elsif raw_url contains 'vimeo.com/' -%}
    {%- assign vimeo_id = raw_url | split: 'vimeo.com/' | last | split: '?' | first | strip -%}
    {%- assign embed_url = 'https://player.vimeo.com/video/' | append: vimeo_id | append: '?autoplay=1' -%}
  {%- endif -%}
{%- endif -%}

{%- assign shopify_video_player_id = 'video-player-' | append: section.id -%}

{%- render 'section-spacing', section: section -%}
<section
  class="video-section section-padding color-scheme color-{{ section.settings.color_scheme }}"
  data-section-id="{{ section.id }}"
>
  <div class="page-width">

    {%- if section.settings.heading != blank or section.settings.description != blank -%}
      <div class="video-section__header">
        {%- if section.settings.heading != blank -%}
          <h2 class="video-section__heading section-heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="video-section__description">{{ section.settings.description | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if has_shopify_video or has_ext_url -%}

      <div
        class="video-section__player-wrap"
        data-video-type="{% if has_shopify_video %}shopify{% else %}embed{% endif %}"
        data-embed-url="{{ embed_url | escape }}"
      >

        {%- comment -%} Cover image / play overlay {%- endcomment -%}
        <div class="video-section__cover" id="video-cover-{{ section.id }}">
          {%- render 'image',
            image: section.settings.poster_image,
            widths: '750,1100,1500',
            sizes: '(min-width: 1024px) 80vw, 100vw',
            alt: section.settings.poster_image.alt | default: section.settings.heading,
            class: 'video-section__poster',
            loading: 'lazy',
            placeholder_type: 'lifestyle-1'
          -%}

          <button
            type="button"
            class="video-section__play-btn"
            aria-label="{{ 'sections.video.play' | t }}"
            data-play-video
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="48" height="48" aria-hidden="true">
              <path d="M8 5v14l11-7z"/>
            </svg>
          </button>
        </div>

        {%- comment -%} Native video (Shopify-hosted) {%- endcomment -%}
        {%- if has_shopify_video -%}
          {{- section.settings.video
            | video_tag:
              class: 'video-section__native hidden',
              id: shopify_video_player_id,
              controls: true,
              playsinline: true,
              preload: 'none',
              loop: false
          -}}
        {%- else -%}
          {%- comment -%} Embed placeholder — iframe injected by JS on play click {%- endcomment -%}
          <div
            class="video-section__embed-target hidden"
            id="video-player-{{ section.id }}"
          ></div>
        {%- endif -%}

      </div>

      <script>
        (function () {
          'use strict';

          const wrap = document.querySelector('[data-section-id="{{ section.id }}"] .video-section__player-wrap');
          if (!wrap) return;

          const cover = wrap.querySelector('.video-section__cover');
          const videoType = wrap.dataset.videoType;
          if (!cover) return;

          function startPlayback() {
            if (cover.getAttribute('data-played') === 'true') return;

            if (videoType === 'shopify') {
              const vid = wrap.querySelector('.video-section__native');
              if (!vid) return;
              cover.setAttribute('data-played', 'true');
              wrap.classList.add('video-section__player-wrap--playing');
              const playBtn = cover.querySelector('.video-section__play-btn');
              if (playBtn) playBtn.hidden = true;
              cover.hidden = true;
              vid.classList.remove('hidden');
              vid.play();
              return;
            }

            const target = wrap.querySelector('.video-section__embed-target');
            const embedUrl = wrap.dataset.embedUrl;
            if (!target || !embedUrl) return;

            cover.setAttribute('data-played', 'true');
            wrap.classList.add('video-section__player-wrap--playing');
            const playBtn = cover.querySelector('.video-section__play-btn');
            if (playBtn) playBtn.hidden = true;
            cover.hidden = true;

            const iframe = document.createElement('iframe');
            iframe.src = embedUrl;
            iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share; fullscreen';
            iframe.allowFullscreen = true;
            iframe.className = 'video-section__iframe';
            iframe.title = {{ section.settings.heading | default: 'Video' | json }};
            target.appendChild(iframe);
            target.classList.remove('hidden');
          }

          cover.addEventListener('click', startPlayback);
        })();
      </script>

    {%- elsif request.design_mode -%}
      <div class="video-section__placeholder">
        <p>Add a Shopify-hosted video or paste a YouTube / Vimeo URL in the editor.</p>
      </div>
    {%- endif -%}

  </div>
</section>

{% stylesheet %}
  /* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
     VIDEO SECTION
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

  .video-section {
    background-color: var(--color-background);
    color: var(--color-foreground);
    padding-block: var(--section-padding-block);
  }

  .video-section__header {
    text-align: center;
    margin-block-end: var(--spacing-xl);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    align-items: center;
  }

  .video-section__heading {
    font-size: var(--font-size-h2);
    font-family: var(--font-heading-family);
    font-weight: var(--font-heading-weight);
    letter-spacing: var(--font-heading-letter-spacing, -0.02em);
    line-height: var(--font-heading-line-height, 1.1);
    margin: 0;
  }

  .video-section__description {
    font-size: 1rem;
    line-height: 1.6;
    opacity: 0.75;
    max-width: 44ch;
    margin: 0;
  }

  /* ── Player wrapper ──────────────────────────────────────────────── */
  .video-section__player-wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-md);
    overflow: hidden;
    background-color: #000;
  }

  /* ── Cover / poster ──────────────────────────────────────────────── */
  .video-section__cover {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .video-section__poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .video-section__cover .image-placeholder {
    position: absolute;
    inset: 0;
  }

  .video-section__cover .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── Play button ─────────────────────────────────────────────────── */
  .video-section__play-btn {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 5rem;
    height: 5rem;
    background-color: rgba(255, 255, 255, 0.9);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    color: #1a1a1a;
    transition:
      background-color var(--transition-base),
      scale var(--transition-base);
  }

  .video-section__play-btn:hover {
    background-color: #fff;
    scale: 1.08;
  }

  .video-section__play-btn:focus-visible {
    outline: 3px solid #fff;
    outline-offset: 4px;
  }

  .video-section__player-wrap--playing .video-section__play-btn {
    display: none !important;
  }

  /* ── Native video & embed ────────────────────────────────────────── */
  .video-section__native,
  .video-section__embed-target,
  .video-section__iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .hidden { display: none !important; }

  /* ── Placeholder ─────────────────────────────────────────────────── */
  .video-section__placeholder {
    aspect-ratio: 16 / 9;
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.5;
    font-size: 0.875rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .video-section__play-btn { transition: none; scale: 1 !important; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.video.name",
  "tag": "section",
  "class": "section-video",
  "settings": [
    {
      "type": "video",
      "id": "video",
      "label": "t:sections.video.settings.video.label"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "t:sections.video.settings.video_url.label",
      "info": "t:sections.video.settings.video_url.info"
    },
    {
      "type": "image_picker",
      "id": "poster_image",
      "label": "t:sections.video.settings.poster_image.label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.video.settings.heading.label"
    },
    {
      "type": "text",
      "id": "description",
      "label": "t:sections.video.settings.description.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:labels.color_scheme",
      "default": "scheme-2"
    },
    {
      "type": "select",
      "id": "section_spacing",
      "label": "t:labels.section_spacing",
      "info": "t:info.section_spacing",
      "options": [
        { "value": "default", "label": "t:options.section_spacing.default" },
        { "value": "none",    "label": "t:options.section_spacing.none"    },
        { "value": "xs",      "label": "t:options.section_spacing.xs"      },
        { "value": "sm",      "label": "t:options.section_spacing.sm"      },
        { "value": "md",      "label": "t:options.section_spacing.md"      },
        { "value": "lg",      "label": "t:options.section_spacing.lg"      },
        { "value": "xl",      "label": "t:options.section_spacing.xl"      }
      ],
      "default": "none"
    }
  ],
  "presets": [
    {
      "name": "t:sections.video.name",
      "settings": {
        "heading": "Behind the craft",
        "description": "A closer look at how our pieces are made."
      }
    }
  ]
}
{% endschema %}
