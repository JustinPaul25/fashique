{% doc %}
  Renders a product price block. Handles:
  - Single price (no compare-at)
  - On-sale price with strikethrough compare-at
  - Price range (when product has multiple price points)
  - Sold-out state
  - Variant-specific pricing (product page use)

  When `variant` is provided, that variant's price is displayed instead of
  the product-level aggregated price. On the product page, JS updates the
  `data-price` / `data-compare-at-price` attributes when a variant changes.

  @param {product} product          - The Shopify product object (required)
  @param {variant} [variant]        - A specific selected variant; falls back to product-level pricing

  @example
  {% render 'price', product: product %}
  {% render 'price', product: product, variant: selected_variant %}
{% enddoc %}

{%- liquid
  if variant
    assign show_price        = variant.price
    assign show_compare      = variant.compare_at_price
    assign price_available   = variant.available
    assign price_varies      = false
  else
    assign show_price        = product.price
    assign show_compare      = product.compare_at_price
    assign price_available   = product.available
    assign price_varies      = product.price_varies
  endif

  assign on_sale   = false
  if show_compare > show_price
    assign on_sale = true
  endif

  assign is_sold_out = false
  unless price_available
    assign is_sold_out = true
  endunless

  assign price_min_money = product.price_min | money
-%}

<div
  class="price{% if on_sale %} price--sale{% endif %}{% if is_sold_out %} price--sold-out{% endif %}"
  data-price="{{ show_price }}"
  data-compare-at-price="{{ show_compare }}"
>
  {%- if is_sold_out -%}

    <span class="price__current price__current--unavailable">
      {{- 'products.price.sold_out' | t -}}
    </span>

  {%- elsif price_varies -%}

    <span class="price__current{% if on_sale %} price__current--sale{% endif %}">
      {{- 'products.price.from_html' | t: price: price_min_money -}}
    </span>

  {%- elsif on_sale -%}

    <span class="price__current price__current--sale" aria-label="{{ 'products.price.sale_price' | t }}">
      {{- show_price | money -}}
    </span>
    <s class="price__was">
      <span class="visually-hidden">{{- 'products.price.regular_price' | t -}}</span>
      {{- show_compare | money -}}
    </s>

  {%- else -%}

    <span class="price__current">
      {{- show_price | money -}}
    </span>

  {%- endif -%}
</div>

{% stylesheet %}
  /* ── Price block ────────────────────────────────────────────────── */
  .price {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  /* ── Current price ──────────────────────────────────────────────── */
  .price__current {
    font-size: var(--price-font-size, 0.9375rem);
    font-weight: 600;
    line-height: 1.2;
  }

  /* Sale colour — inherits from primary token so it adapts to color schemes */
  .price__current--sale {
    color: var(--color-primary);
  }

  /* Sold out — visually de-emphasised */
  .price__current--unavailable {
    font-size: 0.8125rem;
    font-weight: 400;
    font-style: italic;
    opacity: 0.55;
  }

  /* ── Strikethrough compare-at price ─────────────────────────────── */
  .price__was {
    font-size: var(--price-was-font-size, 0.8125rem);
    font-weight: 400;
    opacity: 0.55;
    /* Remove browser's default text-decoration on <s> for consistent styling */
    text-decoration: line-through;
    text-decoration-thickness: 1px;
  }
{% endstylesheet %}
