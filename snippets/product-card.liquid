{% doc %}
  Renders a product card for grids, carousels, and search results.
  Depends on snippets/image.liquid (Phase 4.1).

  @param {product} product             - The Shopify product object (required)
  @param {boolean} [show_vendor]       - Show vendor name above the title (default: false)
  @param {boolean} [show_quick_view]   - Render the Quick View trigger button (default: true)
  @param {boolean} [show_overlay_atc]  - Render an overlay Add-to-Cart button (default: false)
  @param {boolean} [show_swatches]     - Render inline color swatches (default: true)
  @param {string}  [sizes]             - HTML sizes attribute for the product image
  @param {string}  [loading]           - "lazy" (default) or "eager"
  @param {string}  [class]             - Extra CSS classes on the card root

  @example
  {% render 'product-card', product: product %}
  {% render 'product-card',
    product: product,
    show_vendor: true,
    show_overlay_atc: true,
    sizes: "(min-width: 1200px) 33vw, 50vw"
  %}
{% enddoc %}

{%- liquid
  assign is_sold_out       = false
  unless product.available
    assign is_sold_out = true
  endunless

  assign on_sale = false
  if product.compare_at_price > product.price
    assign on_sale = true
  endif

  assign has_single_variant  = false
  if product.variants.size == 1
    assign has_single_variant = true
  endif

  assign render_vendor      = show_vendor      | default: false
  assign render_quick_view  = show_quick_view
  if render_quick_view == nil
    assign render_quick_view = settings.enable_quick_view | default: true
  endif
  assign render_overlay_atc = show_overlay_atc | default: false
  assign render_swatches    = show_swatches    | default: true

  assign sizes   = sizes   | default: '(min-width: 1200px) 25vw, (min-width: 750px) 33vw, 50vw'
  assign loading = loading | default: 'lazy'

  assign color_option = nil
  for option in product.options_with_values
    assign option_name_lower = option.name | downcase
    if option_name_lower == 'color' or option_name_lower == 'colour'
      assign color_option = option
    endif
  endfor

-%}
{%- capture pcard_placeholder_type -%}product-{{ product.id | modulo: 6 | plus: 1 }}{%- endcapture -%}

<div
  class="product-card{% if class != blank %} {{ class }}{% endif %}"
  data-placeholder-type="{{ pcard_placeholder_type }}"
>

  {%- comment -%}── Media ────────────────────────────────────────────────────{%- endcomment -%}
  <div class="product-card__media" data-img-sizes="{{ sizes }}" data-img-loading="{{ loading }}">

    {%- comment -%} Image link — aria-hidden; the title link is the accessible entry point {%- endcomment -%}
    <a
      href="{{ product.url }}"
      class="product-card__media-link"
      tabindex="-1"
      aria-hidden="true"
    >
      {%- render 'image',
        image: product.featured_image,
        widths: '360,540,720,1080',
        sizes: sizes,
        alt: product.featured_image.alt | default: product.title,
        class: 'product-card__img',
        loading: loading,
        placeholder_type: pcard_placeholder_type
      -%}
      {%- if product.images.size > 1 -%}
        {%- render 'image',
          image: product.images[1],
          widths: '360,540,720,1080',
          sizes: sizes,
          alt: product.images[1].alt | default: product.title,
          class: 'product-card__img product-card__img--hover',
          loading: 'lazy'
        -%}
      {%- endif -%}
    </a>

    {%- comment -%} Badges {%- endcomment -%}
    {%- if is_sold_out -%}
      <span class="product-card__badge product-card__badge--sold-out">
        {{- 'products.card.sold_out' | t -}}
      </span>
    {%- elsif on_sale -%}
      <span class="product-card__badge product-card__badge--sale">
        {{- 'products.card.sale' | t -}}
      </span>
    {%- endif -%}

    {%- comment -%} Hover / focus actions {%- endcomment -%}
    <div class="product-card__actions">
      {%- if render_quick_view -%}
        <button
          type="button"
          class="product-card__quick-view btn btn--solid btn--sm"
          data-quick-view="{{ product.handle }}"
          aria-label="{{ 'accessibility.quick_view_product' | t: title: product.title | escape }}"
        >
          {{- 'products.card.quick_view' | t -}}
        </button>
      {%- endif -%}

      {%- if render_overlay_atc -%}
        {%- if is_sold_out -%}
          <span class="product-card__atc btn btn--outline btn--sm" aria-disabled="true">
            {{- 'products.card.sold_out' | t -}}
          </span>
        {%- elsif has_single_variant -%}
          <form action="{{ routes.cart_add_url }}" method="post" class="product-card__atc-form">
            <input type="hidden" name="id" value="{{ product.first_available_variant.id }}">
            <input type="hidden" name="quantity" value="1">
            <button type="submit" class="product-card__atc btn btn--outline btn--sm">
              {{- 'products.card.add_to_cart' | t -}}
            </button>
          </form>
        {%- else -%}
          <a href="{{ product.url }}" class="product-card__atc btn btn--outline btn--sm">
            {{- 'products.card.choose_options' | t -}}
          </a>
        {%- endif -%}
      {%- endif -%}
    </div>

  </div>

  {%- comment -%}── Info ─────────────────────────────────────────────────────{%- endcomment -%}
  <div class="product-card__info">

    {%- if render_vendor and product.vendor != blank -%}
      <p class="product-card__vendor">{{ product.vendor }}</p>
    {%- endif -%}

    <h3 class="product-card__title">
      <a href="{{ product.url }}" class="product-card__title-link">
        {{- product.title | escape -}}
      </a>
    </h3>

    {%- comment -%} Color swatches — Shopify `option_value.swatch` + variant media (Phase 7.3) {%- endcomment -%}
    {%- if render_swatches and color_option != nil -%}
      <div
        class="product-card__swatches"
        role="group"
        aria-label="{{ color_option.name | escape }}"
      >
        {%- for option_value in color_option.values -%}
          {%- liquid
            assign ov_label = option_value.name | default: option_value
            assign ov_variant = option_value.variant
            assign v_img_primary = product.featured_image
            assign v_img_hover = nil
            assign variant_url = product.url
            assign swatch_active = false
            case color_option.position
              when 1
                if product.selected_or_first_available_variant.option1 == ov_label
                  assign swatch_active = true
                endif
              when 2
                if product.selected_or_first_available_variant.option2 == ov_label
                  assign swatch_active = true
                endif
              when 3
                if product.selected_or_first_available_variant.option3 == ov_label
                  assign swatch_active = true
                endif
            endcase
            if ov_variant
              assign variant_url = ov_variant.url | default: product.url
              if ov_variant.featured_image
                assign v_img_primary = ov_variant.featured_image
              endif
              if ov_variant.images.size > 1
                assign v_img_hover = ov_variant.images[1]
              elsif product.images.size > 1
                assign v_img_hover = product.images[1]
              endif
            elsif product.images.size > 1
              assign v_img_hover = product.images[1]
            endif
            assign p_src = v_img_primary | image_url: width: 720
            assign h_src = ''
            if v_img_hover != blank
              assign h_src = v_img_hover | image_url: width: 720
            endif
          -%}
          <div class="product-card__swatch-item">
            <button
              type="button"
              class="swatch swatch--card{% if swatch_active %} is-active{% endif %}"
              title="{{ ov_label | escape }}"
              aria-label="{{ 'products.card.color_swatch_for' | t: value: ov_label }}"
              aria-pressed="{% if swatch_active %}true{% else %}false{% endif %}"
              data-swatch-interactive
              data-media-primary="{{ p_src | escape }}"
              {% if h_src != blank %}
                data-media-hover="{{ h_src | escape }}"
              {% endif %}
              data-variant-url="{{ variant_url | escape }}"
            >
              {%- render 'product-option-color-swatch',
                product: product,
                option_value: option_value,
                label: ov_label,
                swatch_root_class: 'product-card__swatch-root'
              -%}
            </button>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- render 'price', product: product -%}

  </div>
</div>

{% stylesheet %}
  /* ── Product Card ─────────────────────────────────────────────── */
  .product-card {
    display: flex;
    flex-direction: column;
  }

  /* ── Media wrapper ──────────────────────────────────────────────── */
  .product-card__media {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-sm);
    aspect-ratio: 3 / 4;
    background-color: var(--color-border);
  }

  .product-card__media-link {
    display: block;
    height: 100%;
  }

  .product-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity var(--transition-base);
  }

  .product-card__img--hover {
    position: absolute;
    inset: 0;
    opacity: 0;
  }

  @media (hover: hover) {
    .product-card:hover .product-card__img--hover { opacity: 1; }
    .product-card:hover .product-card__img:not(.product-card__img--hover) { opacity: 0; }
  }

  /* ── Badges ─────────────────────────────────────────────────────── */
  .product-card__badge {
    position: absolute;
    top: var(--spacing-sm);
    inset-inline-start: var(--spacing-sm);
    padding: 0.25em 0.625em;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1.5;
    border-radius: var(--radius-sm);
    pointer-events: none;
    z-index: 1;
  }

  .product-card__badge--sale {
    background-color: var(--color-primary);
    color: var(--color-background);
  }

  .product-card__badge--sold-out {
    background-color: color-mix(in srgb, var(--color-foreground) 12%, transparent);
    color: var(--color-foreground);
  }

  /* ── Hover / focus actions ──────────────────────────────────────── */
  .product-card__actions {
    position: absolute;
    inset-inline: var(--spacing-sm);
    bottom: var(--spacing-sm);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
    opacity: 0;
    translate: 0 0.5rem;
    transition:
      opacity var(--transition-base),
      translate var(--transition-base);
    z-index: 2;
  }

  @media (hover: hover) {
    .product-card:hover .product-card__actions,
    .product-card:focus-within .product-card__actions {
      opacity: 1;
      translate: 0 0;
    }
  }

  /* Touch devices: always show actions */
  @media (hover: none) {
    .product-card__actions {
      opacity: 1;
      translate: 0 0;
    }
  }

  .product-card__atc-form {
    display: contents;
  }

  /* ── Info area ──────────────────────────────────────────────────── */
  .product-card__info {
    padding-block: var(--spacing-sm);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 1;
  }

  .product-card__vendor {
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.6;
    margin: 0;
  }

  .product-card__title {
    font-size: 0.9375rem;
    font-weight: 500;
    line-height: 1.3;
    margin: 0;
  }

  .product-card__title-link {
    color: inherit;
    text-decoration: none;
  }

  .product-card__title-link:hover {
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  /* ── Swatches ───────────────────────────────────────────────────── */
  .product-card__swatches {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3125rem;
    margin-block: 0.125rem;
  }

  .swatch {
    padding: 0;
    background: none;
    border: none;
    cursor: pointer;
  }

  .swatch--card {
    width: 1.375rem;
    height: 1.375rem;
    border-radius: 50%;
    border: 1.5px solid var(--color-border);
    transition: border-color var(--transition-base), scale var(--transition-base);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    background: none;
  }

  .product-card__swatch-root {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .product-card__swatch-root .product-section__swatch-img {
    width: 100%;
    height: 100%;
    display: flex;
  }

  .product-card__swatch-root .product-section__swatch-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-card__swatch-root .product-section__swatch-fallback {
    font-size: 0.5rem;
    font-weight: 600;
    line-height: 1;
    text-align: center;
    padding: 0.1rem;
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .swatch--card:hover,
  .swatch--card.is-active {
    border-color: var(--color-primary);
    scale: 1.2;
  }

  .swatch--card:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    scale: 1.2;
  }

  /* ── Price (card context) ────────────────────────────────────────── */
  /* snippets/price.liquid owns the base .price styles.
     This block only adds the card-specific top margin. */
  .product-card__info .price {
    margin-block-start: 0.125rem;
  }
{% endstylesheet %}
