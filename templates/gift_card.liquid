{% layout none %}

<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {% render 'css-variables' %}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}
    <link rel="stylesheet" href="{{ 'spacing.css' | asset_url }}" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="{{ 'spacing.css' | asset_url }}"></noscript>
    {% render 'meta-tags' %}
    {{ content_for_header }}

    {% style %}
      body {
        margin: 0;
        min-height: 100vh;
        font-family: var(--font-body-family);
        font-size: var(--font-body-size);
        color: var(--color-foreground);
        background: var(--color-background);
        line-height: 1.5;
      }

      .gift-card-page {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: var(--spacing-xl) var(--spacing-md);
        box-sizing: border-box;
      }

      .gift-card-page__card {
        width: 100%;
        max-width: 26rem;
        padding: var(--spacing-xl);
        border-radius: var(--radius-lg);
        border: 1px solid var(--color-border);
        background: var(--color-background);
        box-shadow: 0 12px 40px rgb(0 0 0 / 0.08);
        text-align: center;
      }

      .gift-card-page__balance {
        font-family: var(--font-heading-family);
        font-weight: var(--font-heading-weight);
        font-size: clamp(1.75rem, 5vw, 2.25rem);
        margin: 0 0 var(--spacing-sm);
      }

      .gift-card-page__shop {
        font-family: var(--font-heading-family);
        font-weight: var(--font-heading-weight);
        font-size: 1.25rem;
        margin: var(--spacing-md) 0 var(--spacing-xs);
      }

      .gift-card-page__hint {
        margin: 0 0 var(--spacing-md);
        font-size: 0.9375rem;
        opacity: 0.85;
      }

      .gift-card-page__code {
        font-size: 1.25rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        padding: var(--spacing-sm) var(--spacing-md);
        border-radius: var(--radius-sm);
        border: 1px dashed var(--color-border);
        margin: 0 0 var(--spacing-md);
        word-break: break-all;
      }

      .gift-card-page__media {
        margin: var(--spacing-md) 0;
      }

      .gift-card-page__media img {
        max-width: 100%;
        height: auto;
        border-radius: var(--radius-sm);
      }

      .gift-card-page__notice {
        font-size: 0.875rem;
        opacity: 0.8;
        margin: var(--spacing-sm) 0 0;
      }

      .gift-card-page__wallet {
        display: inline-block;
        margin-top: var(--spacing-md);
      }

      .gift-card-page__wallet img {
        display: block;
        max-width: 200px;
        height: auto;
      }
    {% endstyle %}
  </head>

  <body>
    <main class="gift-card-page" id="main-content">
      <div class="gift-card-page__card">
        <h1 class="gift-card-page__balance">{{ gift_card.balance | money }}</h1>

        {%- if gift_card.enabled == false or gift_card.expired -%}
          <p class="gift-card-page__notice">{{ 'gift_card.expired' | t }}</p>
        {%- endif -%}

        {%- if gift_card.expires_on -%}
          {%- assign expires_on = gift_card.expires_on | date: '%B %e, %Y' -%}
          <p class="gift-card-page__notice">{{ 'gift_card.expires_on' | t: expires_on: expires_on }}</p>
        {%- endif -%}

        <div class="gift-card-page__media">
          {%- if settings.logo -%}
            {{ settings.logo | image_url: width: 400 | image_tag: alt: shop.name, loading: 'eager' }}
          {%- else -%}
            <img
              src="{{ 'gift-card/card.svg' | shopify_asset_url }}"
              alt="{{ 'gift_card.card' | t }}"
              width="300"
              height="200"
              loading="eager"
            >
          {%- endif -%}
        </div>

        <h2 class="gift-card-page__shop">{{ shop.name | escape }}</h2>
        <p class="gift-card-page__hint">{{ 'gift_card.use_at_checkout' | t }}</p>
        <p class="gift-card-page__code">{{ gift_card.code | format_code }}</p>

        {%- if gift_card.pass_url -%}
          <a class="gift-card-page__wallet" href="{{ gift_card.pass_url }}">
            <img
              src="{{ 'gift-card/add-to-apple-wallet.svg' | shopify_asset_url }}"
              alt="{{ 'gift_card.add_to_apple_wallet' | t }}"
              width="200"
              height="60"
              loading="lazy"
            >
          </a>
        {%- endif -%}
      </div>
    </main>
  </body>
</html>
